  font-size: 13px; 
  padding: 8px 12px; 
  outline: none; 
  transition: border-color 0.2s;
}

.date-input:focus {
  border-color: var(--bl);
}

.section { display: none; }
.section.active { display: block; }

/* KPI GRID ELEVADO */
.kpi-grid { 
  display: grid; 
  grid-template-columns: repeat(4, 1fr); 
  gap: 20px; 
  margin-bottom: 28px; 
}

.kpi { 
  background: var(--s); 
  border: 1px solid var(--b); 
  border-radius: var(--rad); 
  padding: 24px; 
  box-shadow: var(--shadow);
  transition: transform 0.2s;
}

.kpi:hover {
  transform: translateY(-2px);
}

.kt { font-size: 11px; font-weight: 600; color: var(--m); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px; }
.kv { font-size: 32px; font-weight: 700; color: var(--t); font-family: 'Roboto Mono', monospace; }

/* TARJETA DE PISOS CLARA */
.free-card { 
  background: var(--s); 
  border: 1px solid var(--b); 
  border-radius: var(--rad); 
  padding: 24px; 
  margin-bottom: 28px; 
  box-shadow: var(--shadow);
}

.prow { 
  display: grid; 
  grid-template-columns: 80px 1fr 160px; 
  align-items: center; 
  gap: 16px; 
  margin-bottom: 14px; 
}

.pname { font-weight: 600; color: var(--t); }
.btrack { height: 10px; background: #e1e4e8; border-radius: 6px; overflow: hidden; }
.bfill { height: 100%; border-radius: 6px; transition: width 0.6s ease; }
.pstat { font-family: 'Roboto Mono', monospace; font-size: 12px; text-align: right; color: var(--m); }

/* CONTENEDOR DE GRÁFICOS CLARO */
.cc { 
  background: var(--s); 
  border: 1px solid var(--b); 
  border-radius: var(--rad); 
  padding: 28px; 
  margin-bottom: 24px; 
  box-shadow: var(--shadow);
}

.ctitle { font-size: 12px; font-weight: 600; color: var(--m); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 20px; }

/* TABLA CLARA Y NÍTIDA */
.dt { width: 100%; border-collapse: collapse; font-size: 14px; }
.dt th { text-align: left; padding: 12px 16px; border-bottom: 2px solid var(--b); color: var(--m); font-size: 11px; text-transform: uppercase; font-weight: 600; }
.dt td { padding: 14px 16px; border-bottom: 1px solid #eaecef; color: var(--t); }
.dt tbody tr:hover { background-color: rgba(3,102,214,0.01); }

.pill { display: inline-block; padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; font-family: 'Roboto Mono', monospace; }
.pg { background: rgba(40,167,69,0.1); color: var(--g); border: 1px solid rgba(40,167,69,0.2); }
.pa { background: rgba(246,106,10,0.1); color: var(--a); border: 1px solid rgba(246,106,10,0.2); }
.pr { background: rgba(215,58,73,0.1); color: var(--r); border: 1px solid rgba(215,58,73,0.2); }

.loading { display: flex; align-items: center; justify-content: center; min-height: 100vh; flex-direction: column; gap: 16px; background: var(--bg); color: var(--bl); font-weight: 500; font-size: 16px;}
@media(max-width:1024px){ .shell{grid-template-columns:200px 1fr} .kpi-grid{grid-template-columns:repeat(2,1fr)} }
@media(max-width:768px){ .shell{grid-template-columns:1fr} .sidebar{display:none} .main{padding:24px} .period-bar{padding:12px; gap:10px} }
</style>
</head>
<body>

<div class="shell" id="shell" style="display:none">
  <nav class="sidebar">
    <div class="brand"><div class="brand-title">Workforce Histórico</div></div>
    <div class="nav-item active" onclick="nav('kpis',this)">📊 Resumen ejecutivo</div>
    <div class="nav-item" onclick="nav('daily',this)">📅 Ocupación diaria</div>
    <div class="nav-item" onclick="nav('clients',this)">🏢 Por cliente</div>
  </nav>

  <main class="main">
    <div class="period-bar">
      <label style="font-weight:500; color:var(--m); font-size:12px">DESDE</label>
      <input type="date" class="date-input" id="date-from" onchange="onDateChange()">
      <label style="font-weight:500; color:var(--m); font-size:12px">HASTA</label>
      <input type="date" class="date-input" id="date-to" onchange="onDateChange()">
      <span id="period-info" style="font-size:12px; color:var(--bl); font-weight:500; margin-left:auto"></span>
    </div>

    <div class="section active" id="sec-kpis">
      <div class="kpi-grid">
        <div class="kpi"><div class="kt">POSICIONES ASIGNADAS</div><div class="kv" id="k-pos">-</div></div>
        <div class="kpi"><div class="kt">OCC. PROMEDIO</div><div class="kv" id="k-occ" style="color:var(--bl)">-</div></div>
        <div class="kpi"><div class="kt">PICO MÁXIMO</div><div class="kv" id="k-max">-</div></div>
        <div class="kpi"><div class="kt">DÍA PICO</div><div class="kv" id="k-mf" style="font-size:18px; color:var(--a)">-</div></div>
      </div>

      <div class="free-card">
        <div style="margin-bottom:20px;font-weight:700; font-size:15px">Ocupación por piso <span style="color:var(--m); font-weight:400; font-size:12px">(Día pico del periodo seleccionado)</span></div>
        <div id="piso-rows"></div>
      </div>

      <div class="cc">
        <div class="ctitle">Visualización Usadas vs Libres por piso</div>
        <div style="height:280px"><canvas id="ch-piso"></canvas></div>
      </div>
    </div>

    <div class="section" id="sec-daily">
      <div class="cc">
        <div class="ctitle">Evolución Temporal de Ocupación (FTE Decimal)</div>
        <div style="height:380px"><canvas id="ch-daily"></canvas></div>
      </div>
    </div>

    <div class="section" id="sec-clients">
      <div class="cc" style="padding: 0 0 16px 0">
        <div class="ctitle" style="padding: 28px 28px 0 28px">Detalle por Cliente y Piso <span style="color:var(--m); font-weight:400; font-size:12px">(Basado en día pico)</span></div>
        <table class="dt" id="tbl-cli"></table>
      </div>
    </div>
  </main>
</div>

<div id="loading" class="loading">
  <div style="font-size:30px">⏳</div>
  Cargando base de datos histórica...
</div>

<script>
let RAW=null, dateFrom='', dateTo='', charts={};

// Configuración de colores vívidos globales para Chart.js
Chart.defaults.color = '#6a737d'; // Texto secundaria
Chart.defaults.font.family = "'Inter', sans-serif";
Chart.defaults.borderColor = '#e1e4e8'; // Bordes suaves

const oc = v => v<=80?'#28a745':v<=100?'#f66a0a':'#d73a49'; // Verde, Naranja, Rojo vívidos

async function init(){
  try{
    const res = await fetch('data.json');
    RAW = await res.json();
    const dates = RAW.daily.map(d=>d.Fecha).sort();
    dateFrom = dates[0]; 
    dateTo = dates[dates.length-1];
    document.getElementById('date-from').value = dateFrom;
    document.getElementById('date-to').value = dateTo;
    document.getElementById('loading').style.display='none';
    document.getElementById('shell').style.display='grid';
    render();
  }catch(e){ document.getElementById('loading').textContent='Error al cargar data.json. Asegurate de que el archivo existe.'; }
}

function onDateChange(){
  dateFrom = document.getElementById('date-from').value;
  dateTo = document.getElementById('date-to').value;
  render();
}

function render(){
  const data = RAW.daily.filter(d => d.Fecha >= dateFrom && d.Fecha <= dateTo);
  const asigMap = RAW.meta.asigMap;
  const totalPos = RAW.meta.total_pos;

  const lab = data.filter(d => d.dow > 0 && d.dow < 6);
  const labAvg = lab.length ? (lab.reduce((s,d)=>s+d.occ_pct,0)/lab.length).toFixed(1) : 0;
  const maxOcc = lab.length ? Math.max(...lab.map(d=>d.occ_pct)) : 0;
  const maxDayRaw = lab.find(d=>d.occ_pct === maxOcc)?.Fecha || '-';
  
  // Formatear fecha para el KPI
  let maxDayDisp = maxDayRaw;
  if(maxDayRaw !== '-') {
      const df = new Date(maxDayRaw + 'T12:00:00');
      maxDayDisp = df.toLocaleDateString('es-AR', { day: '2-digit', month: 'short' });
  }

  document.getElementById('k-pos').textContent = totalPos;
  document.getElementById('k-occ').textContent = labAvg + '%';
  document.getElementById('k-max').textContent = maxOcc + '%';
  document.getElementById('k-mf').textContent = maxDayDisp;
  document.getElementById('period-info').textContent = `Actualizado: ${RAW.meta.updated}`;

  // Calculo de pisos basado en día pico con DECIMALES
  const peakCli = (maxDayRaw !== '-' && RAW.daily_per_client[maxDayRaw]) ? RAW.daily_per_client[maxDayRaw] : {};
  const pisoStats = {};
  
  for(const [cli, info] of Object.entries(asigMap)){
    const p = info.piso;
    if(!pisoStats[p]) pisoStats[p] = {used: 0, total: 0};
    pisoStats[p].total += info.pos;
    // Captura decimales del JSON para una ocupación exacta
    pisoStats[p].used += Math.min(parseFloat(peakCli[cli] || 0), info.pos);
  }

  const prows = document.getElementById('piso-rows'); prows.innerHTML = '';
  Object.entries(pisoStats).sort((a,b)=>a[0].localeCompare(b[0])).forEach(([p, s]) => {
    const pct = (s.used/s.total*100).toFixed(1);
    prows.innerHTML += `
      <div class="prow">
        <span class="pname">Piso ${p}</span>
        <div class="btrack"><div class="bfill" style="width:${pct}%;background:${oc(pct)}"></div></div>
        <span class="pstat">${s.used.toFixed(1)} / ${s.total}</span>
      </div>`;
  });

  renderCharts(data, pisoStats);
  renderTable(peakCli, asigMap);
}

function renderCharts(data, pisoStats){
  // GRÁFICO DIARIO VÍVIDO
  if(charts.daily) charts.daily.destroy();
  charts.daily = new Chart(document.getElementById('ch-daily'), {
    type:'line',
    data: {
      labels: data.map(d => {
          const date = new Date(d.Fecha + 'T12:00:00');
          return date.toLocaleDateString('es-AR', { weekday: 'short', day: '2-digit' });
      }),
      datasets: [{
        label: 'Agentes (FTE Decimal)',
        data: data.map(d=>d.pico_total),
        borderColor: '#0366d6', // Azul vívido
        backgroundColor: 'rgba(3,102,214,0.06)',
        fill: true,
        tension: 0.3,
        pointBackgroundColor: '#0366d6',
        pointRadius: 3,
        borderWidth: 2
      }]
    },
    options: { 
        responsive: true, 
        maintainAspectRatio: false,
        plugins: { legend: { display: false } }, // Ocultar leyenda
        scales: {
            y: {
                beginAtZero: true,
                grid: { color: '#eaecef' }
            },
            x: {
                grid: { display: false }
            }
        }
    }
  });

  // GRÁFICO PISOS VÍVIDO
  if(charts.piso) charts.piso.destroy();
  charts.piso = new Chart(document.getElementById('ch-piso'), {
    type:'bar',
    data: {
      labels: Object.keys(pisoStats).map(p=>'Piso '+p),
      datasets: [{
        label: 'Ocupados',
        data: Object.values(pisoStats).map(s=>s.used.toFixed(1)),
        backgroundColor: '#28a745', // Verde vívido
        borderRadius: 4
      },{
        label: 'Libres',
        data: Object.values(pisoStats).map(s=>(s.total - s.used).toFixed(1)),
        backgroundColor: '#e1e4e8', // Gris suave
        borderRadius: 4
      }]
    },
    options: { 
        responsive: true, 
        maintainAspectRatio: false, 
        plugins: { legend: { position: 'bottom', labels: { boxWidth: 12 } } },
        scales: { 
            x:{stacked:true, grid: { display: false }}, 
            y:{stacked:true, grid: { color: '#eaecef' }} 
        } 
    }
  });
}

function renderTable(peakCli, asigMap){
  const tbl = document.getElementById('tbl-cli');
  let html = `<thead><tr><th>Cliente</th><th>Piso</th><th>Pos. Asignadas</th><th>Usadas (Peak)</th><th>Estado</th></tr></thead><tbody>`;
  
  Object.entries(asigMap).sort((a,b)=>b[1].pos - a[1].pos).forEach(([cli, info]) => {
    const used = parseFloat(peakCli[cli] || 0).toFixed(1);
    const pos = info.pos;
    const pct = pos > 0 ? (used / pos * 100).toFixed(1) : 0;
    
    // Pill de estado basada en ocupación decimal
    let pillClass = 'pg'; // Normal
    if (pct > 90) pillClass = 'pa'; // Alerta
    if (pct > 100) pillClass = 'pr'; // Crítico

    html += `<tr>
      <td style="font-weight:600">${cli}</td>
      <td style="color:var(--m)">${info.piso}</td>
      <td style="font-family:Roboto Mono">${pos}</td>
      <td style="font-family:Roboto Mono; font-weight:600; color:var(--bl)">${used}</td>
      <td><span class="pill ${pillClass}">${pct}%</span></td>
    </tr>`;
  });
  tbl.innerHTML = html + `</tbody>`;
}

function nav(id, el){
  document.querySelectorAll('.section').forEach(s=>s.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  document.getElementById('sec-'+id).classList.add('active');
  el.classList.add('active');
}

init();
</script>
</body>
</html>
Principales cambios en esta versión:
Palaba de Colores: Pasamos del negro a un fondo casi blanco (#fafbfc) y tarjetas blanco puro (#ffffff). Los colores de acento (verde, rojo, azul) son ahora mucho más saturados y vívidos.

Tipografías: He actualizado a Inter (para texto general, más nítida) y Roboto Mono (para números, más legible y profesional).

UI Elements:

Sidebar: Ahora es blanco, con iconos y un color azul de acento para la selección.

Tarjetas (KPIs, Gráficos): Tienen bordes suaves y una sombra leve (box-shadow) para dar sensación de elevación y limpieza.

Inputs de Fecha: Son blancos y con bordes definidos.

Gráficos (Chart.js): He actualizado la configuración global de Chart.js para que las líneas, cuadrículas y textos coincidan con el modo claro. El gráfico de evolución diaria ahora usa un azul GitHub vívido.

Tabla: Más espaciada, con líneas divisorias grises muy finas y una "pill" de porcentaje de ocupación rediseñada para ser más colorida.

¡Espero que este nuevo look "Light Mode Vívid" te guste! Decime si querés ajustar algún color o si pasamos a la siguiente modificación.

Has dicho
de la solapa que figura ahi la parte de Workforce historico cambialo por ocupación historica. OCC promedio sacalo, día pico esta mal porque figura 4 de febrero y la información es de Marzo. Piso 3 y piso 4 entiendo que esta programado para que si sobrepasa el Q de posiciones asiganadas lo real presencial ponga el 100% de ocupación, pero necesito modificarlo para que el limite lo mantenga pero sume las posiciones sobrantes al otro piso. Esto solo debe hacerse con personal 3 (Piso 3) y personal 4 (piso 4). Me explique?

Gemini ha dicho
Entendido, vamos a aplicar estos ajustes de precisión y lógica de negocio. Lo que planteas para Personal es un sistema de "rebalse": si un piso se llena, el excedente se visualiza en el otro, manteniendo el tope físico pero reflejando la realidad de la operación.

Aquí tienes el código de index.html con las cuatro modificaciones aplicadas:

Cambio de Título: "Ocupación Histórica" en la barra lateral.

Eliminación de KPI: Se quitó la tarjeta de "OCC. PROMEDIO".

Corrección de Fecha: Se ajustó el formato para asegurar que muestre la fecha de marzo correctamente.

Lógica de Rebalse (Piso 3 <=> 4): Si Personal 3 supera sus 213 posiciones, el sobrante se suma al uso del Piso 4 (y viceversa).

HTML
<nav class="sidebar">
    <div class="brand"><div class="brand-title">Ocupación Histórica</div></div>
    <div class="nav-item active" onclick="nav('kpis',this)">📊 Resumen ejecutivo</div>
