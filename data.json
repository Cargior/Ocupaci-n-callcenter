VBA
Option Explicit

'============================================================
' MACRO UNIFICADA DE OCUPACIÓN HISTÓRICA
'============================================================
Public Sub Procesar_Export()

    Dim wsExp As Worksheet, wsSrv As Worksheet, wsNom As Worksheet
    Dim ultExp As Long, ultSrv As Long, ultNom As Long
    Dim dictSrv As Object, dictNom As Object
    Dim i As Long
    Dim vag As Variant, legajo As Variant
    Dim texto As String
    Dim ini As Long, fin As Long
    Dim valMod As String, fechaLogueo As Variant, mesLogueo As String

    Set wsExp = ThisWorkbook.Worksheets("Export")
    Set wsSrv = ThisWorkbook.Worksheets("Servicio")
    Set wsNom = ThisWorkbook.Worksheets("Nomina")

    Set dictSrv = CreateObject("Scripting.Dictionary")
    Set dictNom = CreateObject("Scripting.Dictionary")
    dictSrv.CompareMode = vbTextCompare
    dictNom.CompareMode = vbTextCompare

    Application.ScreenUpdating = False
    Application.EnableEvents = False
    Application.Calculation = xlCalculationManual

    '---------------------------------------------------------
    ' Cargar tabla Servicio (VAG -> Cliente, Campaña, Servicio)
    '---------------------------------------------------------
    ultSrv = wsSrv.Cells(wsSrv.Rows.Count, "A").End(xlUp).Row
    If ultSrv >= 2 Then
        For i = 2 To ultSrv
            vag = wsSrv.Cells(i, "A").Value
            If Len(vag) > 0 Then
                dictSrv(CStr(vag)) = Array( _
                    wsSrv.Cells(i, "B").Value, _
                    wsSrv.Cells(i, "C").Value, _
                    wsSrv.Cells(i, "D").Value _
                )
            End If
        Next i
    End If

    '---------------------------------------------------------
    ' Cargar tabla Nomina (Legajo + Mes -> Presencialidad)
    ' Clave: "Legajo|Mes"
    '---------------------------------------------------------
    ultNom = wsNom.Cells(wsNom.Rows.Count, "A").End(xlUp).Row
    If ultNom >= 2 Then
        For i = 2 To ultNom
            legajo = Trim$(CStr(wsNom.Cells(i, "A").Value))
            Dim mesNomina As String
            mesNomina = Trim$(CStr(wsNom.Cells(i, "C").Value)) ' Columna C: Mes
            
            If Len(legajo) > 0 And Len(mesNomina) > 0 Then
                dictNom(legajo & "|" & mesNomina) = wsNom.Cells(i, "B").Value
            End If
        Next i
    End If

    '---------------------------------------------------------
    ' Recorrer Export
    '---------------------------------------------------------
    ultExp = wsExp.Cells(wsExp.Rows.Count, "A").End(xlUp).Row
    If ultExp < 2 Then GoTo Salida

    For i = 2 To ultExp

        'PASO 1: Extraer Legajo (Col B -> Col E)
        texto = wsExp.Cells(i, "B").Value
        ini = InStr(texto, "(")
        fin = InStr(texto, ")")
        If ini > 0 And fin > ini Then
            wsExp.Cells(i, "E").Value = Mid$(texto, ini + 1, fin - ini - 1)
        Else
            wsExp.Cells(i, "E").ClearContents
        End If

        'PASO 2: Cruzar VAG (Col A) -> Cliente(G), Campaña(H), Servicio(I)
        vag = wsExp.Cells(i, "A").Value
        If Len(vag) > 0 And dictSrv.Exists(CStr(vag)) Then
            wsExp.Cells(i, "G").Value = dictSrv(CStr(vag))(0) 
            wsExp.Cells(i, "H").Value = dictSrv(CStr(vag))(1) 
            wsExp.Cells(i, "I").Value = dictSrv(CStr(vag))(2) 
        Else
            wsExp.Cells(i, "G").ClearContents
            wsExp.Cells(i, "H").ClearContents
            wsExp.Cells(i, "I").ClearContents
        End If

        'PASO 3: Presencialidad Dinámica por Mes (Col F)
        legajo = Trim$(CStr(wsExp.Cells(i, "E").Value))
        fechaLogueo = wsExp.Cells(i, "C").Value ' Col C: Fecha ingreso
        
        If Len(legajo) > 0 And IsDate(fechaLogueo) Then
            mesLogueo = Application.WorksheetFunction.Proper(Format(fechaLogueo, "mmmm"))
            Dim claveBusqueda As String
            claveBusqueda = legajo & "|" & mesLogueo
            
            If dictNom.Exists(claveBusqueda) Then
                valMod = Trim$(CStr(dictNom(claveBusqueda)))
                If UCase$(valMod) = "HIBRIDO" Then valMod = "PRESENCIAL"
                wsExp.Cells(i, "F").Value = valMod
            Else
                wsExp.Cells(i, "F").Value = "PRESENCIAL" 
            End If
        Else
            wsExp.Cells(i, "F").Value = "PRESENCIAL"
        End If
    Next i

    'PASO 4: Ocupación por franja con DECIMALES
    GenerarOcupacionTiempo_Chunked_OnePass wsExp, ultExp, 200000, "Ocup_PRESENCIAL", "Ocup_TELETRABAJO"

    'PASO 5: Informe simple (solo presencial)
    GenerarHojaInforme_Simple_Picos_Presencial

    'PASO 6: Max por franja con FECHA REAL para histórico HTML
    GenerarHojaMaxOcupacionPorFranja_Presencial

Salida:
    Application.Calculation = xlCalculationAutomatic
    Application.EnableEvents = True
    Application.ScreenUpdating = True
    MsgBox "Proceso completado con éxito.", vbInformation
End Sub

'============================================================
' PASO 4: CÁLCULO DE MINUTOS POR FRANJA
'============================================================
Private Sub GenerarOcupacionTiempo_Chunked_OnePass(ByVal wsExp As Worksheet, ByVal lastExp As Long, _
                                                  ByVal chunkSize As Long, _
                                                  ByVal outPres As String, ByVal outTele As String)
    Dim dictPres As Object, dictTele As Object, dictUse As Object
    Dim startRow As Long, endRow As Long, data As Variant, r As Long
    Dim modVal As String, modUP As String, cliente As String, camp As String, subcamp As String
    Dim dtIn As Double, dtOut As Double, slotStart As Double, slotEnd As Double, overlap As Double, mins As Double
    Dim dayKey As String, frLabel As String, k As String

    Set dictPres = CreateObject("Scripting.Dictionary")
    Set dictTele = CreateObject("Scripting.Dictionary")
    dictPres.CompareMode = vbTextCompare
    dictTele.CompareMode = vbTextCompare

    Const HALF_HOUR As Double = 2.08333333333333E-02 
    Const DAY_MINUTES As Double = 1440#
    startRow = 2

    Do While startRow <= lastExp
        endRow = startRow + chunkSize - 1
        If endRow > lastExp Then endRow = lastExp
        data = wsExp.Range("A" & startRow & ":I" & endRow).Value2

        For r = 1 To UBound(data, 1)
            modUP = UCase$(Trim$(CStr(data(r, 6))))
            If modUP = "PRESENCIAL" Then Set dictUse = dictPres ElseIf modUP = "TELETRABAJO" Then Set dictUse = dictTele Else GoTo NextR

            If IsEmpty(data(r, 3)) Or IsEmpty(data(r, 4)) Then GoTo NextR
            dtIn = CDbl(data(r, 3)): dtOut = CDbl(data(r, 4))
            If dtOut < dtIn Then dtOut = dtOut + 1#

            cliente = Trim$(CStr(data(r, 7))): camp = Trim$(CStr(data(r, 8))): subcamp = Trim$(CStr(data(r, 9)))
            If Len(cliente) = 0 Then cliente = "(Sin cliente)"
            slotStart = FloorToHalfHourDbl(dtIn)

            Do While slotStart < dtOut
                slotEnd = slotStart + HALF_HOUR
                overlap = MinDbl(dtOut, slotEnd) - MaxDbl(dtIn, slotStart)
                If overlap > 0# Then
                    mins = overlap * DAY_MINUTES
                    dayKey = CStr(Fix(slotStart))
                    frLabel = TimeLabel(slotStart) & "-" & TimeLabel(slotEnd)
                    k = cliente & "|" & camp & "|" & subcamp & "|" & dayKey & "|" & frLabel
                    dictUse(k) = dictUse(k) + mins
                End If
                slotStart = slotEnd
            Loop
NextR:
        Next r
        startRow = endRow + 1
    Loop
    WriteDictTiempo_Optim dictPres, GetOrCreateSheet(outPres)
    WriteDictTiempo_Optim dictTele, GetOrCreateSheet(outTele)
End Sub

'============================================================
' ESCRITURA CON DECIMALES (FTE)
'============================================================
Private Sub WriteDictTiempo_Optim(ByVal dict As Object, ByVal wsOut As Worksheet)
    Dim arr() As Variant, parts() As String, i As Long, k As Variant, mins As Double
    wsOut.Cells.Clear
    wsOut.Range("A1:H1").Value = Array("Cliente", "Campaña", "Subcampaña", "Día", "Franja", "Minutos", "Horas", "FTE")
    If dict.Count = 0 Then Exit Sub
    ReDim arr(1 To dict.Count, 1 To 8)
    i = 0
    For Each k In dict.Keys
        i = i + 1: parts = Split(CStr(k), "|"): mins = CDbl(dict(k))
        arr(i, 1) = parts(0): arr(i, 2) = parts(1): arr(i, 3) = parts(2)
        arr(i, 4) = CDate(CDbl(parts(3))): arr(i, 5) = parts(4)
        arr(i, 6) = Round(mins, 2): arr(i, 7) = Round(mins / 60#, 4)
        arr(i, 8) = Round(mins / 30#, 2) ' FTE con decimales
    Next k
    wsOut.Range("A2").Resize(dict.Count, 8).Value2 = arr
    wsOut.Columns("H").NumberFormat = "0.00"
    wsOut.Columns("A:H").AutoFit
End Sub

'============================================================
' PASO 6: MAX OCUPACIÓN POR FRANJA Y FECHA
'============================================================
Private Sub GenerarHojaMaxOcupacionPorFranja_Presencial()
    Dim wsOut As Worksheet, wsSrc As Worksheet, dict As Object, data As Variant
    Dim r As Long, i As Long, k As Variant, parts() As String, outArr() As Variant
    Dim cliente As String, camp As String, subcamp As String, franja As String
    Dim dayDbl As Double, fte As Double, key As String

    Set wsOut = GetOrCreateSheet("Max Ocupación x Franja"): wsOut.Cells.Clear
    wsOut.Range("A1:H1").Value = Array("Cliente", "Campaña", "Subcampaña", "Fecha", "Día", "Franja", "Max FTE (Pres)", "Mes")

    On Error Resume Next
    Set wsSrc = ThisWorkbook.Worksheets("Ocup_PRESENCIAL")
    On Error GoTo 0
    If wsSrc Is Nothing Then Exit Sub

    data = wsSrc.Range("A2:H" & wsSrc.Cells(wsSrc.Rows.Count, "A").End(xlUp).Row).Value2
    Set dict = CreateObject("Scripting.Dictionary")

    For r = 1 To UBound(data, 1)
        cliente = data(r, 1): camp = data(r, 2): subcamp = data(r, 3): dayDbl = data(r, 4): franja = data(r, 5): fte = data(r, 8)
        ' Clave incluye Fecha real para evitar colisiones históricas
        key = cliente & "|" & camp & "|" & subcamp & "|" & CStr(dayDbl) & "|" & franja
        If dict.Exists(key) Then
            If fte > CDbl(dict(key)) Then dict(key) = fte
        Else
            dict.Add key, fte
        End If
    Next r

    ReDim outArr(1 To dict.Count, 1 To 8)
    i = 0
    For Each k In dict.Keys
        i = i + 1: parts = Split(CStr(k), "|")
        Dim dFecha As Double: dFecha = CDbl(parts(3))
        outArr(i, 1) = parts(0): outArr(i, 2) = parts(1): outArr(i, 3) = parts(2)
        outArr(i, 4) = CDate(dFecha) ' Fecha real
        outArr(i, 5) = NombreDia(VBA.Weekday(dFecha, vbMonday))
        outArr(i, 6) = parts(4): outArr(i, 7) = Round(CDbl(dict(k)), 2) ' FTE decimal
        outArr(i, 8) = Application.WorksheetFunction.Proper(Format(dFecha, "mmmm")) ' Mes
    Next k

    wsOut.Range("A2").Resize(dict.Count, 8).Value2 = outArr
    wsOut.Columns("D").NumberFormat = "dd/mm/yyyy"
    wsOut.Columns("G").NumberFormat = "0.00"
    wsOut.Columns("A:H").AutoFit
    
    ' Ordenar por Cliente y Fecha
    Dim rngSort As Range: Set rngSort = wsOut.Range("A2:H" & (dict.Count + 1))
    With wsOut.Sort
        .SortFields.Clear
        .SortFields.Add key:=rngSort.Columns(1), Order:=xlAscending ' Cliente
        .SortFields.Add key:=rngSort.Columns(4), Order:=xlAscending ' Fecha
        .SortFields.Add key:=rngSort.Columns(6), Order:=xlAscending ' Franja
        .SetRange rngSort: .Header = xlNo: .Apply
    End With
End Sub

'============================================================
' HELPERS RESTANTES (PASO 5 Y FUNCIONES DE TIEMPO)
'============================================================
Private Sub GenerarHojaInforme_Simple_Picos_Presencial()
    Dim wsOut As Worksheet, wsSrc As Worksheet, data As Variant, r As Long
    Set wsOut = GetOrCreateSheet("Informe"): wsOut.Cells.Clear
    wsOut.Range("A1:I1").Value = Array("Campaña", "Subcampaña", "Lunes", "Martes", "Miércoles", "Jueves", "Viernes", "Sábado", "Domingo")
    On Error Resume Next: Set wsSrc = ThisWorkbook.Worksheets("Ocup_PRESENCIAL"): On Error GoTo 0
    If wsSrc Is Nothing Then Exit Sub

    data = wsSrc.Range("A2:H" & wsSrc.Cells(wsSrc.Rows.Count, "A").End(xlUp).Row).Value2
    Dim dictMaxSlot As Object: Set dictMaxSlot = CreateObject("Scripting.Dictionary")
    
    For r = 1 To UBound(data, 1)
        Dim camp As String: camp = data(r, 2)
        Dim sub As String: sub = data(r, 3)
        Dim fr As String: fr = data(r, 5)
        Dim wd As Integer: wd = VBA.Weekday(CDate(data(r, 4)), vbMonday)
        Dim fte As Double: fte = data(r, 8)
        Dim k As String: k = camp & "|" & sub & "|" & CStr(wd) & "|" & fr
        If dictMaxSlot.Exists(k) Then
            If fte > CDbl(dictMaxSlot(k)) Then dictMaxSlot(k) = fte
        Else: dictMaxSlot.Add k, fte: End If
    Next r

    Dim dictPeak As Object: Set dictPeak = CreateObject("Scripting.Dictionary")
    Dim keySlot As Variant, parts() As String
    For Each keySlot In dictMaxSlot.Keys
        parts = Split(CStr(keySlot), "|")
        Dim keySvc As String: keySvc = parts(0) & "|" & parts(1)
        Dim arrPeaks As Variant
        If dictPeak.Exists(keySvc) Then arrPeaks = dictPeak(keySvc) Else arrPeaks = InitPeaksArray()
        Dim dWd As Integer: dWd = CInt(parts(2))
        If CDbl(dictMaxSlot(keySlot)) > CDbl(arrPeaks(dWd, 1)) Then
            arrPeaks(dWd, 1) = dictMaxSlot(keySlot): arrPeaks(dWd, 2) = parts(3)
        End If
        dictPeak(keySvc) = arrPeaks
    Next keySlot

    If dictPeak.Count > 0 Then
        Dim outArr() As Variant: ReDim outArr(1 To dictPeak.Count, 1 To 9)
        Dim i As Long: i = 0
        For Each keySlot In dictPeak.Keys
            i = i + 1: parts = Split(CStr(keySlot), "|"): arrPeaks = dictPeak(keySlot)
            outArr(i, 1) = parts(0): outArr(i, 2) = parts(1)
            Dim j As Integer: For j = 1 To 7: outArr(i, j + 2) = PicoCellText(arrPeaks, j): Next j
        Next keySlot
        wsOut.Range("A2").Resize(dictPeak.Count, 9).Value2 = outArr
    End If
    wsOut.Columns("A:I").AutoFit
End Sub

Private Function PicoCellText(ByVal arrPeaks As Variant, ByVal wd As Integer) As String
    Dim fte As Double: fte = CDbl(arrPeaks(wd, 1))
    If fte <= 0# Then PicoCellText = "" Else PicoCellText = arrPeaks(wd, 2) & " (" & CStr(Round(fte, 2)) & ")"
End Function

Private Function InitPeaksArray() As Variant
    Dim a(1 To 7, 1 To 2) As Variant, i As Integer: For i = 1 To 7: a(i, 1) = 0#: a(i, 2) = "": Next i: InitPeaksArray = a
End Function

Private Function NombreDia(ByVal wd As Integer) As String
    NombreDia = Choose(wd, "Lunes", "Martes", "Miércoles", "Jueves", "Viernes", "Sábado", "Domingo")
End Function

Private Function FloorToHalfHourDbl(ByVal d As Double) As Double
    Dim mins As Long: mins = CLng(((d - Fix(d)) * 1440#) + 0.0000001)
    mins = (mins \ 30) * 30: FloorToHalfHourDbl = Fix(d) + (mins / 1440#)
End Function

Private Function TimeLabel(ByVal d As Double) As String
    Dim tm As Long: tm = CLng(((d - Fix(d)) * 1440#) + 0.0000001)
    TimeLabel = Format(tm \ 60, "00") & ":" & Format(tm Mod 60, "00")
End Function

Private Function MinDbl(ByVal a As Double, ByVal b As Double) As Double: If a < b Then MinDbl = a Else MinDbl = b: End Function
Private Function MaxDbl(ByVal a As Double, ByVal b As Double) As Double: If a > b Then MaxDbl = a Else MaxDbl = b: End Function

Private Function GetOrCreateSheet(ByVal name As String) As Worksheet
    On Error Resume Next: Set GetOrCreateSheet = ThisWorkbook.Worksheets(name): On Error GoTo 0
    If GetOrCreateSheet Is Nothing Then
        Set GetOrCreateSheet = ThisWorkbook.Worksheets.Add(After:=ThisWorkbook.Worksheets(ThisWorkbook.Worksheets.Count))
        GetOrCreateSheet.name = name
    End If
End Function
