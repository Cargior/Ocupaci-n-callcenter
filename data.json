<style>
:root{--bg:#0f0f10;--s:#18181b;--s2:#1f1f23;--b:rgba(255,255,255,0.07);--t:#f0ede8;--m:#888480;--g:#22c98a;--a:#f5a623;--r:#e05252;--bl:#4a9eff;--rad:10px}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--t);font-family:'DM Sans',sans-serif;font-size:14px;min-height:100vh}
.shell{display:grid;grid-template-columns:220px 1fr;min-height:100vh}
.sidebar{background:var(--s);border-right:1px solid var(--b);padding:28px 0;position:sticky;top:0;height:100vh;overflow-y:auto;display:flex;flex-direction:column}
.main{padding:32px 40px;max-width:1120px}
.brand{padding:0 22px 24px;border-bottom:1px solid var(--b);margin-bottom:20px}
.brand-title{font-size:13px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--g)}
.nav-item{display:flex;align-items:center;gap:10px;padding:9px 22px;font-size:13px;color:var(--m);cursor:pointer;border-left:2px solid transparent;transition:all .15s}
.nav-item.active{color:var(--t);border-left-color:var(--g);background:rgba(34,201,138,.06)}
.section{display:none}.section.active{display:block}
.period-bar{background:var(--s);border:1px solid var(--b);border-radius:var(--rad);padding:14px 20px;margin-bottom:24px;display:flex;align-items:center;gap:14px;flex-wrap:wrap}
.date-input{background:var(--s2);border:1px solid var(--b);border-radius:6px;color:var(--t);font-family:'DM Mono',monospace;font-size:12px;padding:6px 10px;outline:none}
.kpi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:20px}
.kpi{background:var(--s);border:1px solid var(--b);border-radius:var(--rad);padding:18px 20px;position:relative}
