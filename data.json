HTML
<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Ocupación Histórica</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Roboto+Mono&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
:root {
  --bg: #f7f8f9; --s: #ffffff; --b: #e6e8eb; --t: #1a1f23; --m: #6a737d;
  --g: #2ea44f; --a: #f66a0a; --r: #d73a49; --bl: #0366d6;
  --shadow: 0 1px 3px rgba(0,0,0,0.04), 0 1px 2px rgba(0,0,0,0.08);
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body { background: var(--bg); color: var(--t); font-family: 'Inter', sans-serif; font-size: 14px; }
.shell { display: grid; grid-template-columns: 260px 1fr; min-height: 100vh; }
.sidebar { background: var(--s); border-right: 1px solid var(--b); padding: 32px 0; position: sticky; top: 0; height: 100vh; display: flex; flex-direction: column; }
.brand { padding: 0 24px 28px; border-bottom: 1px solid var(--b); margin-bottom: 24px; }
.brand-title { font-size: 16px; font-weight: 700; color: var(--t); }
.nav-item { display: flex; align-items: center; gap: 12px; padding: 12px 24px; color: var(--m); cursor: pointer; transition: 0.15s; border-radius: 8px; margin: 0 12px 4px; font-weight: 500; }
.nav-item.active { color: var(--bl); background: rgba(3,102,214,0.07); font-weight: 600; }
.main { padding: 48px; max-width: 1400px; margin: 0 auto; width: 100%; }
.period-bar { background: var(--s); border: 1px solid var(--b); border-radius: 12px; padding: 18px 28px; margin-bottom: 32px; display: flex; align-items: center; gap: 16px; box-shadow: var(--shadow); }
.date-input { background: var(--bg); border: 1px solid #d1d5da; border-radius: 6px; padding: 10px 14px; font-family: 'Roboto Mono'; font-size: 13px; outline: none; }
.section { display: none; }
.section.active { display: block; }
.kpi-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-bottom: 32px; }
.kpi { background: var(--s); border: 1px solid var(--b); border-radius: 12px; padding: 28px; box-shadow: var(--shadow); }
.kt { font-size: 12px; font-weight: 600; color: var(--m); text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 10px; }
.kv { font-size: 36px; font-weight: 700; font-family: 'Roboto Mono'; }
.cc { background: var(--s); border: 1px solid var(--b); border-radius: 12px; padding: 32px; margin-bottom: 24px; box-shadow: var(--shadow); }
.ctitle { font-size: 13px; font-weight: 600; color: var(--m); text-transform: uppercase; margin-bottom: 24px; }
.prow { display: grid; grid-template-columns: 90px 1fr 180px; align-items: center; gap: 20px; margin-bottom: 16px; }
.pname { font-weight: 600; font-size: 15px; }
.btrack { height: 12px; background: #e1e4e8; border-radius: 6px; overflow: hidden; }
.bfill { height: 100%; border-radius: 6px; transition: width 0.6s ease; }
.pstat { font-family: 'Roboto Mono'; font-size: 13px; text-align: right; color: var(--m); }
.dt { width: 100%; border-collapse: collapse; }
.dt th { text-align: left; padding: 14px 18px; border-bottom: 2px solid #d1d5da; font-size: 12px; text-transform: uppercase; font-weight: 700; }
.dt td { padding: 16px 18px; border-bottom: 1px solid #eaecef; }
.pill { padding: 5px 12px; border-radius: 20px; font-size: 12px; font-weight: 600; font-family: 'Roboto Mono'; }
.pg { background: rgba(46,164,79,0.1); color: var(--g); border: 1px solid rgba(46,164,79,0.2); }
.pr { background: rgba(215,58,73,0.1); color: var(--r); border: 1px solid rgba(215,58,73,0.2); }
.loading { display: flex; align-items: center; justify-content: center; min-height: 100vh; flex-direction: column; gap: 20px; font-weight: 600; font-size: 18px; color: var(--bl); }
</style>
</head>
<body>

<div id="loading" class="loading">⏳ Cargando base de datos histórica...</div>

<div class="shell" id="shell" style="display:none">
  <nav class="sidebar">
    <div class="brand"><div class="brand-title">Ocupación Histórica</div></div>
    <div class="nav-item active" onclick="nav('kpis',this)">📊 Resumen ejecutivo</div>
    <div class="nav-item" onclick="nav('daily',this)">📅 Ocupación diaria</div>
    <div class="nav-item" onclick="nav('clients',this)">🏢 Por cliente</div>
  </nav>
  <main class="main">
    <div class="period-bar">
      <input type="date" class="date-input" id="date-from" onchange="onDateChange()">
      <input type="date" class="date-input" id="date-to" onchange="onDateChange()">
      <span id="period-info" style="margin-left:auto; color:var(--bl); font-weight:600"></span>
    </div>

    <div class="section active" id="sec-kpis">
      <div class="kpi-grid">
        <div class="kpi"><div class="kt">POSICIONES ASIGNADAS</div><div class="kv" id="k-pos">-</div></div>
        <div class="kpi"><div class="kt">PICO MÁXIMO</div><div class="kv" id="k-max">-</div></div>
        <div class="kpi"><div class="kt">DÍA PICO</div><div class="kv" id="k-mf" style="font-size:18px; color:var(--a); font-family:'Inter'">-</div></div>
      </div>

      <div class="kpi-grid" style="grid-template-columns: 2fr 1fr;">
        <div class="cc">
          <div class="ctitle">Distribución por Franja Horaria (Día Pico)</div>
          <div style="height:300px"><canvas id="ch-hourly"></canvas></div>
        </div>
        <div class="cc">
          <div class="ctitle">Eficiencia de Puestos</div>
          <div id="efficiency-rank"></div>
        </div>
      </div>

      <div class="cc">
        <div class="ctitle">Ocupación real por piso (Rebalse P3-P4)</div>
        <div id="piso-rows"></div>
      </div>
    </div>

    <div class="section" id="sec-daily"><div class="cc"><div style="height:400px"><canvas id="ch-daily"></canvas></div></div></div>
    <div class="section" id="sec-clients"><div class="cc" style="padding:0"><table class="dt" id="tbl-cli"></table></div></div>
  </main>
</div>

<script>
let RAW=null, dateFrom='', dateTo='', charts={};
const oc = v => v<=80?'#2ea44f':v<=100?'#f66a0a':'#d73a49';

async function init(){
  try {
    const res = await fetch('data.json');
    RAW = await res.json();
    const dates = RAW.daily.map(d=>d.Fecha).sort();
    dateFrom=dates[0]; dateTo=dates[dates.length-1];
    document.getElementById('date-from').value=dateFrom;
    document.getElementById('date-to').value=dateTo;
    document.getElementById('loading').style.display='none';
    document.getElementById('shell').style.display='grid';
    render();
  } catch(e) { document.getElementById('loading').textContent='Error al cargar data.json'; }
}

function onDateChange(){
  dateFrom=document.getElementById('date-from').value;
  dateTo=document.getElementById('date-to').value;
  render();
}

function clearView() {
    if(charts.daily) charts.daily.destroy();
    if(charts.hourly) charts.hourly.destroy();
    document.getElementById('piso-rows').innerHTML = '<div style="color:var(--m); padding:20px; text-align:center">Sin datos</div>';
}

function render(){
  const data = RAW.daily.filter(d => d.Fecha >= dateFrom && d.Fecha <= dateTo);
  if (data.length === 0) { clearView(); return; }

  const asigMap = RAW.meta.asigMap;
  const maxOcc = Math.max(...data.map(d=>d.occ_pct));
  const maxDayRaw = data.find(d=>d.occ_pct === maxOcc)?.Fecha || '-';
  
  if(maxDayRaw !== '-') {
      const p = maxDayRaw.split('-');
      const dLocal = new Date(parseInt(p[0]), parseInt(p[1]) - 1, parseInt(p[2]));
      document.getElementById('k-mf').textContent = dLocal.toLocaleDateString('es-AR', {day:'2-digit', month:'long'});
  }

  document.getElementById('k-pos').textContent = RAW.meta.total_pos;
  document.getElementById('k-max').textContent = maxOcc + '%';
  document.getElementById('period-info').textContent = 'Actualizado: ' + RAW.meta.updated;

  const peakCli = (maxDayRaw !== '-' && RAW.daily_per_client[maxDayRaw]) ? RAW.daily_per_client[maxDayRaw] : {};
  const capP3 = asigMap["PERSONAL 3"]?.pos || 213;
  const capP4 = asigMap["PERSONAL 4"]?.pos || 152;
  const fP3 = Math.min(parseFloat(peakCli["PERSONAL 3"]||0), capP3) + Math.max(0, parseFloat(peakCli["PERSONAL 4"]||0) - capP4);
  const fP4 = Math.min(parseFloat(peakCli["PERSONAL 4"]||0), capP4) + Math.max(0, parseFloat(peakCli["PERSONAL 3"]||0) - capP3);

  const pisoStats = {};
  for(const [cli, info] of Object.entries(asigMap)){
    const p = info.piso;
    if(!pisoStats[p]) pisoStats[p] = {used: 0, total: 0};
    pisoStats[p].total += info.pos;
    let v = parseFloat(peakCli[cli] || 0);
    if(cli === "PERSONAL 3") v = fP3;
    if(cli === "PERSONAL 4") v = fP4;
    pisoStats[p].used += v;
  }

  const prows = document.getElementById('piso-rows'); prows.innerHTML = '';
  Object.entries(pisoStats).sort().forEach(([p, s]) => {
    const pct = (s.used/s.total*100).toFixed(1);
    prows.innerHTML += `<div class="prow"><span class="pname">Piso ${p}</span><div class="btrack"><div class="bfill" style="width:${Math.min(pct,100)}%;background:${oc(pct)}"></div></div><span class="pstat">${s.used.toFixed(1)} / ${s.total}</span></div>`;
  });

  renderHourlyChart(maxDayRaw);
  renderEfficiencyRank(peakCli, asigMap, fP3, fP4);
  renderCharts(data);
  renderTable(peakCli, asigMap, fP3, fP4);
}

function renderHourlyChart(day) {
  if(charts.hourly) charts.hourly.destroy();
  const dayData = RAW.hourly_distribution[day] || {};
  const labels = Object.keys(dayData).sort();
  charts.hourly = new Chart(document.getElementById('ch-hourly'), {
    type: 'bar',
    data: { labels, datasets: [{ label: 'Agentes', data: labels.map(l=>dayData[l].toFixed(1)), backgroundColor: 'rgba(3,102,214,0.1)', borderColor: '#0366d6', borderWidth: 1 }] },
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
  });
}

function renderEfficiencyRank(peakCli, asigMap, f3, f4) {
  const clients = Object.entries(asigMap).map(([cli, info]) => {
    let used = parseFloat(peakCli[cli] || 0);
    if(cli === "PERSONAL 3") used = f3; if(cli === "PERSONAL 4") used = f4;
    return { cli, pct: (used / info.pos * 100) };
  }).sort((a,b) => b.pct - a.pct);

  let h = '<div style="font-size:12px"><strong>Top Uso:</strong><br>';
  clients.slice(0,3).forEach(c => h += `<div style="display:flex; justify-content:space-between; margin-top:4px"><span>${c.cli}</span><span style="color:var(--r); font-weight:600">${c.pct.toFixed(0)}%</span></div>`);
  h += '<br><strong>Sub-utilizados:</strong><br>';
  clients.slice(-3).reverse().forEach(c => h += `<div style="display:flex; justify-content:space-between; margin-top:4px"><span>${c.cli}</span><span style="color:var(--g); font-weight:600">${c.pct.toFixed(0)}%</span></div>`);
  document.getElementById('efficiency-rank').innerHTML = h + '</div>';
}

function renderTable(peakCli, asigMap, f3, f4){
  const tbl = document.getElementById('tbl-cli');
  let h = `<thead><tr><th>Cliente</th><th>Piso</th><th>Posiciones</th><th>Usadas</th><th>Estado</th></tr></thead><tbody>`;
  Object.entries(asigMap).sort((a,b)=>b[1].pos-a[1].pos).forEach(([cli, info]) => {
    let u = parseFloat(peakCli[cli] || 0);
    if(cli === "PERSONAL 3") u = f3; if(cli === "PERSONAL 4") u = f4;
    const pct = (u / info.pos * 100).toFixed(1);
    h += `<tr><td style="font-weight:600">${cli}</td><td>${info.piso}</td><td>${info.pos}</td><td style="color:var(--bl); font-weight:600">${u.toFixed(1)}</td><td><span class="pill ${pct>100?'pr':'pg'}">${pct}%</span></td></tr>`;
  });
  tbl.innerHTML = h + `</tbody>`;
}

function renderCharts(data){
  if(charts.daily) charts.daily.destroy();
  charts.daily = new Chart(document.getElementById('ch-daily'), {
    type:'line', data: { labels: data.map(d=>d.Fecha), datasets: [{ data: data.map(d=>d.pico_total), borderColor: '#0366d6', backgroundColor: 'rgba(3,102,214,0.05)', fill: true, tension: 0.3 }] },
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
  });
}

function nav(id, el){
  document.querySelectorAll('.section').forEach(s=>s.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  document.getElementById('sec-'+id).classList.add('active'); el.classList.add('active');
}
init();
</script>
</body>
</html>
