body { background: var(--bg); color: var(--t); font-family: 'Inter', sans-serif; font-size: 14px; }
.shell { display: grid; grid-template-columns: 260px 1fr; min-height: 100vh; }
.sidebar { background: var(--s); border-right: 1px solid var(--b); padding: 32px 0; position: sticky; top: 0; height: 100vh; display: flex; flex-direction: column; }
