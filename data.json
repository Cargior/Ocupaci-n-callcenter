Private Sub GenerarHojaMaxOcupacionPorFranja_Presencial()
    Dim wsOut As Worksheet, wsSrc As Worksheet, dict As Object, data As Variant
    Dim r As Long, i As Long, k As Variant, parts() As String, outArr() As Variant
    Dim cliente As String, camp As String, subcampName As String, franja As String
