.nav-item.active { color: var(--bl); background: rgba(3,102,214,0.07); font-weight: 600; }
.main { padding: 48px; max-width: 1400px; margin: 0 auto; width: 100%; }
.period-bar { background: var(--s); border: 1px solid var(--b); border-radius: 12px; padding: 18px 28px; margin-bottom: 32px; display: flex; align-items: center; gap: 16px; box-shadow: var(--shadow); }
.date-input { background: var(--bg); border: 1px solid #d1d5da; border-radius: 6px; padding: 10px 14px; font-family: 'Roboto Mono'; font-size: 13px; outline: none; }
