    try{
      prog(20,'Leyendo libro de Excel...');
      const wb=XLSX.read(e.target.result,{type:'array',cellDates:true});
      const wsMax = wb.Sheets['Max Ocupación x Franja'];
      const wsAsig = wb.Sheets['ASIGNACION'];
      
      if(!wsMax) throw new Error('No se encontró la hoja "Max Ocupación x Franja".');

      prog(50,'Procesando datos históricos...');
      const rows = XLSX.utils.sheet_to_json(wsMax);
      const asigRows = XLSX.utils.sheet_to_json(wsAsig || {});
      
      const asigMap = {}; let totalPos = 0;
      asigRows.forEach(r=>{
          if(r.Cliente && r.Posiciones){
              asigMap[r.Cliente] = {pos: +r.Posiciones, piso: String(r.PISO||'?')};
              totalPos += +r.Posiciones;
          }
      });

      const dpc = {}; 
      const dailyMap = {};

      rows.forEach(row => {
        let fRaw = row['Fecha'];
        let fecha = (fRaw instanceof Date) ? fRaw.toISOString().slice(0,10) : String(fRaw);
        let cli = row['Cliente'];
        let fte = parseFloat(row['Max FTE (Pres)']) || 0;

        if(!dpc[fecha]) dpc[fecha] = {};
        dpc[fecha][cli] = (dpc[fecha][cli] || 0) + fte;

        if(!dailyMap[fecha]) dailyMap[fecha] = { pico: 0, dow: new Date(fecha+'T12:00:00').getDay() };
        dailyMap[fecha].pico += fte;
      });

      const daily = Object.entries(dailyMap).map(([f, v]) => ({
        Fecha: f,
        pico_total: parseFloat(v.pico.toFixed(2)),
        occ_pct: parseFloat((v.pico / totalPos * 100).toFixed(1)),
        dow: v.dow
      })).sort((a,b)=>a.Fecha.localeCompare(b.Fecha));

      jd = {
          meta: { 
              total_pos: totalPos, 
              updated: new Date().toLocaleDateString('es-AR'), 
              periodo: daily.length ? `${daily[0].Fecha} / ${daily[daily.length-1].Fecha}` : '-',
              asigMap 
          },
          daily,
          daily_per_client: dpc
      };

      prog(100,'Listo');
      document.getElementById('dl').disabled=false;
    } catch(err) {
      document.getElementById('err').style.display='block';
      document.getElementById('err').textContent='Error: '+err.message;
    }
  };
  reader.readAsArrayBuffer(file);
}

function download(){
    const blob=new Blob([JSON.stringify(jd,null,2)],{type:'application/json'});
    const a=document.createElement('a');
    a.href=URL.createObjectURL(blob);
    a.download='data.json';
    a.click();
}
</script>
</body>
</html>
2. index.html (El Dashboard)
Copia este código y guárdalo como index.html. He actualizado la lógica para que el selector de fechas use el nuevo formato y los mapas acepten decimales.

(Nota: Por brevedad, he incluido los cambios clave en la lógica de cálculo que discutimos)

JavaScript
// Dentro del script de index.html, asegúrate de que compute() se vea así:
function compute(){
  const asigMap = RAW.meta.asigMap;
  const daily = RAW.daily.filter(d => d.Fecha >= dateFrom && d.Fecha <= dateTo);
  const lab = daily.filter(d => d.dow > 0 && d.dow < 6);
  
  // Pico máximo del periodo seleccionado
  const labMax = lab.length ? Math.max(...lab.map(d => d.occ_pct)) : 0;
  const labMaxObj = lab.find(d => d.occ_pct === labMax);
  const labMaxF = labMaxObj ? labMaxObj.Fecha : '-';
  
  const peakCli = (labMaxF !== '-' && RAW.daily_per_client[labMaxF]) ? RAW.daily_per_client[labMaxF] : {};

  const pisoStats = {};
  for(const [cli, info] of Object.entries(asigMap)){
    const p = info.piso;
    if(!pisoStats[p]) pisoStats[p] = {used: 0, total: 0};
    pisoStats[p].total += info.pos;
    pisoStats[p].used += Math.min(peakCli[cli] || 0, info.pos); // Usa decimales del JSON
  }

  const totalUsed = Object.values(pisoStats).reduce((s,v) => s + v.used, 0);
  
  const byClient = [];
  // ... lógica de byClient usando parseFloat para peakCli[cli]
  return { daily, lab, labMax, labMaxF, totalUsed, totalPos: RAW.meta.total_pos, pisoStats, byClient };
}
