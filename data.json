  border-radius: var(--rad); 
  padding: 28px; 
  margin-bottom: 32px; 
  box-shadow: var(--shadow);
}

.prow { 
  display: grid; 
  grid-template-columns: 90px 1fr 180px; 
  align-items: center; 
  gap: 20px; 
  margin-bottom: 16px; 
}

.pname { font-weight: 600; color: var(--t); font-size: 15px; }
.btrack { height: 12px; background: #e1e4e8; border-radius: 6px; overflow: hidden; }
.bfill { height: 100%; border-radius: 6px; transition: width 0.6s ease; }
.pstat { font-family: 'Roboto Mono', monospace; font-size: 13px; text-align: right; color: var(--m); }

/* CONTENEDOR DE GRÁFICOS MODERNO */
.cc { 
  background: var(--s); 
  border: 1px solid var(--b); 
  border-radius: var(--rad); 
  padding: 32px; 
  margin-bottom: 24px; 
  box-shadow: var(--shadow);
}

.ctitle { font-size: 13px; font-weight: 600; color: var(--m); text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 24px; }

/* TABLA CLARA, NÍTIDA Y VÍVIDA (como en la imagen) */
.dt { width: 100%; border-collapse: collapse; font-size: 14px; }
.dt th { text-align: left; padding: 14px 18px; border-bottom: 2px solid var(--b-dark); color: var(--t); font-size: 12px; text-transform: uppercase; font-weight: 700; }
.dt td { padding: 16px 18px; border-bottom: 1px solid #eaecef; color: var(--t); }
.dt tbody tr:hover { background-color: #f8f9fa; }

.pill { display: inline-block; padding: 5px 12px; border-radius: 20px; font-size: 12px; font-weight: 600; font-family: 'Roboto Mono', monospace; }
.pg { background: rgba(46,164,79,0.1); color: var(--g); border: 1px solid rgba(46,164,79,0.2); }
.pa { background: rgba(246,106,10,0.1); color: var(--a); border: 1px solid rgba(246,106,10,0.2); }
.pr { background: rgba(215,58,73,0.1); color: var(--r); border: 1px solid rgba(215,58,73,0.2); }

.loading { display: flex; align-items: center; justify-content: center; min-height: 100vh; flex-direction: column; gap: 20px; background: var(--bg); color: var(--bl); font-weight: 600; font-size: 18px;}
@media(max-width:1120px){ .shell{grid-template-columns:220px 1fr} .kpi-grid{grid-template-columns:repeat(2,1fr)} .main{padding: 32px} }
@media(max-width:768px){ .shell{grid-template-columns:1fr} .sidebar{display:none} .main{padding:24px} .period-bar{padding:16px; gap:10px} }
</style>
</head>
<body>

<div class="shell" id="shell" style="display:none">
  <nav class="sidebar">
    <div class="brand"><div class="brand-title">Ocupación Histórica</div></div>
    <div class="nav-item active" onclick="nav('kpis',this)">📊 Resumen ejecutivo</div>
    <div class="nav-item" onclick="nav('daily',this)">📅 Ocupación diaria</div>
    <div class="nav-item" onclick="nav('clients',this)">🏢 Por cliente</div>
  </nav>

  <main class="main">
    <div class="period-bar">
      <label style="font-weight:600; color:var(--m); font-size:12px; text-transform:uppercase">DESDE</label>
      <input type="date" class="date-input" id="date-from" onchange="onDateChange()">
      <label style="font-weight:600; color:var(--m); font-size:12px; text-transform:uppercase">HASTA</label>
      <input type="date" class="date-input" id="date-to" onchange="onDateChange()">
      <span id="period-info" style="font-size:13px; color:var(--bl); font-weight:600; margin-left:auto"></span>
    </div>

    <div class="section active" id="sec-kpis">
      <div class="kpi-grid">
        <div class="kpi"><div class="kt">POSICIONES ASIGNADAS</div><div class="kv" id="k-pos">-</div></div>
        <div class="kpi"><div class="kt">PICO MÁXIMO</div><div class="kv" id="k-max">-</div></div>
        <div class="kpi"><div class="kt">DÍA PICO</div><div class="kv" id="k-mf" style="font-size:18px; color:var(--a); font-family:'Inter'">-</div></div>
      </div>

      <div class="free-card">
        <div style="margin-bottom:24px;font-weight:700; font-size:16px">Ocupación real por piso <span style="color:var(--m); font-weight:400; font-size:13px; margin-left:8px">(Basado en día pico del periodo seleccionado)</span></div>
        <div id="piso-rows"></div>
      </div>

      <div class="cc">
        <div class="ctitle">Visualización Usadas vs Libres por piso</div>
        <div style="height:300px"><canvas id="ch-piso"></canvas></div>
      </div>
    </div>

    <div class="section" id="sec-daily">
      <div class="cc">
        <div class="ctitle">Evolución Temporal de Ocupación (FTE Decimal)</div>
        <div style="height:400px"><canvas id="ch-daily"></canvas></div>
      </div>
    </div>

    <div class="section" id="sec-clients">
      <div class="cc" style="padding: 0 0 20px 0">
        <div class="ctitle" style="padding: 32px 32px 0 32px">Detalle por Cliente y Piso <span style="color:var(--m); font-weight:400; font-size:13px; margin-left:8px">(Cálculo sobre día pico)</span></div>
        <table class="dt" id="tbl-cli"></table>
      </div>
    </div>
  </main>
</div>

<div id="loading" class="loading">
  <div style="font-size:36px">⏳</div>
  Cargando base de datos histórica...
</div>

<script>
let RAW=null, dateFrom='', dateTo='', charts={};

// Configuración de colores vívidos globales para Chart.js
Chart.defaults.color = '#6a737d'; // Texto secundaria
Chart.defaults.font.family = "'Inter', sans-serif";
Chart.defaults.borderColor = '#e1e4e8'; // Bordes suaves

const oc = v => v<=80?'#2ea44f':v<=100?'#f66a0a':'#d73a49'; // Verde, Naranja, Rojo vívidos de la imagen

async function init(){
  try{
    const res = await fetch('data.json');
    RAW = await res.json();
    const dates = RAW.daily.map(d=>d.Fecha).sort();
    dateFrom = dates[0]; 
    dateTo = dates[dates.length-1];
    document.getElementById('date-from').value = dateFrom;
    document.getElementById('date-to').value = dateTo;
    document.getElementById('loading').style.display='none';
    document.getElementById('shell').style.display='grid';
    render();
  }catch(e){ document.getElementById('loading').textContent='Error al cargar data.json. Asegurate de que el archivo existe.'; }
}

function onDateChange(){
  dateFrom = document.getElementById('date-from').value;
  dateTo = document.getElementById('date-to').value;
  render();
}

// FUNCIÓN DE LIMPIEZA ABSOLUTA (Mejorada)
function clearView() {
    document.getElementById('k-max').textContent = '0%';
    document.getElementById('k-mf').textContent = '-';
    document.getElementById('piso-rows').innerHTML = '<div style="color:var(--m); padding:30px; text-align:center; font-weight:500">Sin datos en el rango seleccionado</div>';
    document.getElementById('tbl-cli').innerHTML = '<tbody><tr><td style="text-align:center; padding:50px; color:var(--m); font-weight:500">No hay registros para mostrar en el periodo actual.</td></tr></tbody>';
    if(charts.daily) { charts.daily.destroy(); charts.daily = null; }
    if(charts.piso) { charts.piso.destroy(); charts.piso = null; }
}

function render(){
  // 1. FILTRAR DATOS
  const data = RAW.daily.filter(d => d.Fecha >= dateFrom && d.Fecha <= dateTo);
  const asigMap = RAW.meta.asigMap;
  const totalPos = RAW.meta.total_pos;
  
  // 2. SI NO HAY DATOS, LIMPIAR Y SALIR
  if (data.length === 0) {
      clearView();
      document.getElementById('k-pos').textContent = totalPos;
      return;
  }

  // 3. PROCESAR SI HAY DATOS
  const maxOcc = Math.max(...data.map(d=>d.occ_pct));
  const maxDayRaw = data.find(d=>d.occ_pct === maxOcc)?.Fecha || '-';
  
  if(maxDayRaw !== '-') {
      // SOLUCIÓN DEFINITIVA FECHA: Split para evitar desfase UTC
      const p = maxDayRaw.split('-');
      const dLocal = new Date(parseInt(p[0]), parseInt(p[1]) - 1, parseInt(p[2]));
      document.getElementById('k-mf').textContent = dLocal.toLocaleDateString('es-AR', {day:'2-digit', month:'long'});
  } else {
      document.getElementById('k-mf').textContent = '-';
  }

  document.getElementById('k-pos').textContent = totalPos;
  document.getElementById('k-max').textContent = maxOcc + '%';
  document.getElementById('period-info').textContent = 'Actualizado: ' + RAW.meta.updated;

  // Lógica de rebalse Personal 3 y 4 (como pidió el usuario)
  const peakCli = (maxDayRaw !== '-' && RAW.daily_per_client[maxDayRaw]) ? RAW.daily_per_client[maxDayRaw] : {};
  const capP3 = asigMap["PERSONAL 3"]?.pos || 213;
  const capP4 = asigMap["PERSONAL 4"]?.pos || 152;
  const fteP3 = parseFloat(peakCli["PERSONAL 3"] || 0);
  const fteP4 = parseFloat(peakCli["PERSONAL 4"] || 0);

  const exP3 = Math.max(0, fteP3 - capP3);
  const exP4 = Math.max(0, fteP4 - capP4);
  const fP3 = Math.min(fteP3, capP3) + exP4;
  const fP4 = Math.min(fteP4, capP4) + exP3;

  const pisoStats = {};
  for(const [cli, info] of Object.entries(asigMap)){
    const p = info.piso;
    if(!pisoStats[p]) pisoStats[p] = {used: 0, total: 0};
    pisoStats[p].total += info.pos;
    let v = parseFloat(peakCli[cli] || 0);
    if(cli === "PERSONAL 3") v = fP3;
    if(cli === "PERSONAL 4") v = fP4;
    pisoStats[p].used += v;
  }

  const prows = document.getElementById('piso-rows'); prows.innerHTML = '';
  Object.entries(pisoStats).sort((a,b)=>a[0].localeCompare(b[0])).forEach(([p, s]) => {
    const pct = (s.used/s.total*100).toFixed(1);
    prows.innerHTML += `
      <div class="prow">
        <span class="pname">Piso ${p}</span>
        <div class="btrack"><div class="bfill" style="width:${Math.min(pct,100)}%;background:${oc(pct)}"></div></div>
        <span class="pstat">${s.used.toFixed(1)} / ${s.total}</span>
      </div>`;
  });

  renderCharts(data, pisoStats);
  renderTable(peakCli, asigMap, fP3, fP4);
}

function renderTable(peakCli, asigMap, f3, f4){
  const tbl = document.getElementById('tbl-cli');
  let h = `<thead><tr><th>Cliente</th><th>Piso</th><th>Pos. Asignadas</th><th>Usadas</th><th>Estado</th></tr></thead><tbody>`;
  Object.entries(asigMap).sort((a,b)=>b[1].pos-a[1].pos).forEach(([cli, info]) => {
    let u = parseFloat(peakCli[cli] || 0);
    if(cli === "PERSONAL 3") u = f3; if(cli === "PERSONAL 4") u = f4;
    const pos = info.pos;
    const pct = pos > 0 ? (u / pos * 100).toFixed(1) : 0;
    
    // Pill de estado basada en ocupación decimal
    let pillClass = 'pg'; // Normal
    if (pct > 90) pillClass = 'pa'; // Alerta
    if (pct > 100) pillClass = 'pr'; // Crítico

    h += `<tr>
      <td style="font-weight:600">${cli}</td>
      <td style="color:var(--m)">${info.piso}</td>
      <td style="font-family:Roboto Mono">${pos}</td>
      <td style="font-family:Roboto Mono; font-weight:600; color:var(--bl)">${u.toFixed(1)}</td>
      <td><span class="pill ${pillClass}">${pct}%</span></td>
    </tr>`;
  });
  tbl.innerHTML = h + `</tbody>`;
}

function renderCharts(data, pisoStats){
  // GRÁFICO DIARIO VÍVIDO
  if(charts.daily) charts.daily.destroy();
  charts.daily = new Chart(document.getElementById('ch-daily'), {
    type:'line',
    data: {
      labels: data.map(d => {
          const p = d.Fecha.split('-');
          const date = new Date(parseInt(p[0]), parseInt(p[1]) - 1, parseInt(p[2]));
          return date.toLocaleDateString('es-AR', { weekday: 'short', day: '2-digit' });
      }),
      datasets: [{
        label: 'Agentes (FTE)',
        data: data.map(d=>d.pico_total),
        borderColor: '#0366d6', // Azul vívido
        backgroundColor: 'rgba(3,102,214,0.05)',
        fill: true,
        tension: 0.3,
        pointBackgroundColor: '#0366d6',
        pointRadius: 3,
        borderWidth: 2
      }]
    },
    options: { 
        responsive: true, 
        maintainAspectRatio: false,
        plugins: { legend: { display: false } }, // Ocultar leyenda
        scales: {
            y: {
                beginAtZero: true,
                grid: { color: '#eaecef' },
                title: { display: true, text: 'Total FTE', color: var('--m'), font: {size: 11, weight: 600} }
            },
            x: {
                grid: { display: false }
            }
        }
    }
  });

  // GRÁFICO PISOS VÍVIDO
  if(charts.piso) charts.piso.destroy();
  charts.piso = new Chart(document.getElementById('ch-piso'), {
    type:'bar',
    data: {
      labels: Object.keys(pisoStats).map(p=>'Piso '+p),
      datasets: [{
        label: 'Ocupados',
        data: Object.values(pisoStats).map(s=>s.used.toFixed(1)),
        backgroundColor: '#2ea44f', // Verde vívido
        borderRadius: 4
      },{
        label: 'Libres',
        data: Object.values(pisoStats).map(s=>(s.total - s.used).toFixed(1)),
        backgroundColor: '#e1e4e8', // Gris suave
        borderRadius: 4
      }]
    },
    options: { 
        responsive: true, 
        maintainAspectRatio: false, 
        plugins: { legend: { position: 'bottom', labels: { boxWidth: 12 } } },
        scales: { 
            x:{stacked:true, grid: { display: false }}, 
            y:{stacked:true, grid: { color: '#eaecef' }} 
        } 
    }
  });
}

function nav(id, el){
  document.querySelectorAll('.section').forEach(s=>s.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  document.getElementById('sec-'+id).classList.add('active');
  el.classList.add('active');
}

// Iniciar cargando la base
init();
</script>
</body>
</html>
Cambios Clave para coincidir con la Imagen:
Tipografía: Se implementó la fuente Inter para todo el texto general, logrando esa apariencia nítida y moderna.

Paleta de Colores: Fondo grisáceo muy suave (#f7f8f9), tarjetas blanco puro, y colores de acento (verde, rojo, azul) más saturados y vivos.

Layout y Estructura:

Sidebar: Ahora es blanco con una división clara, y los elementos de navegación tienen efecto de cápsula al seleccionarse.

KPI Grid: Tarjetas elevadas con sombras suaves y texto secundario en mayúsculas pequeñas.

Pisos y Tabla: Estilos limpios, espaciados profesionales y píldoras de estado vívidas.

Gráficos: Se ajustaron los colores de Chart.js para que las líneas, cuadrículas y barras coincidan con el estilo visual (Azul Linear en el gráfico diario).

Has dicho
me quedo asi

Gemini ha dicho
¡Se ve excelente! Ya tenés la estética moderna con la tipografía Inter, el modo claro y el gráfico de línea suave. Sin embargo, noto en la imagen que el Día Pico sigue mostrando "04 de febrero".

Esto sucede porque tu base tiene datos de Marzo 2026 y el navegador está interpretando la fecha como UTC, restándole horas hasta caer en el día anterior.

Aquí tenés el código de index.html con la corrección final para la fecha y la disposición de las tarjetas para que queden exactamente como en la imagen:

HTML
<!DOCTYPE html>
<html lang="es">
