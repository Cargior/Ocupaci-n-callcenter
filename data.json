        outArr(i, 1) = parts(0): outArr(i, 2) = parts(1): outArr(i, 3) = parts(2)
        outArr(i, 4) = CDate(dFecha) 
        outArr(i, 5) = NombreDia(VBA.Weekday(dFecha, vbMonday))
        outArr(i, 6) = parts(4): outArr(i, 7) = Round(CDbl(dict(k)), 2)
        outArr(i, 8) = Application.WorksheetFunction.Proper(Format(dFecha, "mmmm"))
    Next k

    wsOut.Range("A2").Resize(dict.Count, 8).Value2 = outArr
    wsOut.Columns("D").NumberFormat = "dd/mm/yyyy"
    wsOut.Columns("G").NumberFormat = "0.00"
    
    Dim rngSort As Range: Set rngSort = wsOut.Range("A2:H" & (dict.Count + 1))
    With wsOut.Sort
        .SortFields.Clear
        .SortFields.Add key:=rngSort.Columns(1), Order:=xlAscending 
        .SortFields.Add key:=rngSort.Columns(4), Order:=xlAscending 
        .SortFields.Add key:=rngSort.Columns(6), Order:=xlAscending 
        .SetRange rngSort: .Header = xlNo: .Apply
    End With
    wsOut.Columns("A:H").AutoFit
End Sub

'============================================================
' PASO 5: INFORME SIMPLE DE PICOS
'============================================================
Private Sub GenerarHojaInforme_Simple_Picos_Presencial()
    Dim wsOut As Worksheet, wsSrc As Worksheet, data As Variant, r As Long
    Dim campName As String, subName As String, frName As String, keyK As String
    Dim wdIdx As Integer, fteVal As Double

    Set wsOut = GetOrCreateSheet("Informe"): wsOut.Cells.Clear
    wsOut.Range("A1:I1").Value = Array("Campaña", "Subcampaña", "Lunes", "Martes", "Miércoles", "Jueves", "Viernes", "Sábado", "Domingo")
    On Error Resume Next: Set wsSrc = ThisWorkbook.Worksheets("Ocup_PRESENCIAL"): On Error GoTo 0
    If wsSrc Is Nothing Then Exit Sub

    data = wsSrc.Range("A2:H" & wsSrc.Cells(wsSrc.Rows.Count, "A").End(xlUp).Row).Value2
    Dim dictMaxSlot As Object: Set dictMaxSlot = CreateObject("Scripting.Dictionary")
    
    For r = 1 To UBound(data, 1)
        campName = data(r, 2)
        subName = data(r, 3)
        frName = data(r, 5)
        wdIdx = VBA.Weekday(CDate(data(r, 4)), vbMonday)
        fteVal = data(r, 8)
        keyK = campName & "|" & subName & "|" & CStr(wdIdx) & "|" & frName
        
        If dictMaxSlot.Exists(keyK) Then
            If fteVal > CDbl(dictMaxSlot(keyK)) Then dictMaxSlot(keyK) = fteVal
        Else
            dictMaxSlot.Add keyK, fteVal
        End If
    Next r

    Dim dictPeak As Object: Set dictPeak = CreateObject("Scripting.Dictionary")
    Dim keyS As Variant, partsS() As String
    For Each keyS In dictMaxSlot.Keys
        partsS = Split(CStr(keyS), "|")
        Dim keySvc As String: keySvc = partsS(0) & "|" & partsS(1)
        Dim arrPeaks As Variant
        If dictPeak.Exists(keySvc) Then arrPeaks = dictPeak(keySvc) Else arrPeaks = InitPeaksArray()
        Dim curWd As Integer: curWd = CInt(partsS(2))
        If CDbl(dictMaxSlot(keyS)) > CDbl(arrPeaks(curWd, 1)) Then
            arrPeaks(curWd, 1) = dictMaxSlot(keyS): arrPeaks(curWd, 2) = partsS(3)
        End If
        dictPeak(keySvc) = arrPeaks
    Next keyS

    If dictPeak.Count > 0 Then
        Dim outArr() As Variant: ReDim outArr(1 To dictPeak.Count, 1 To 9)
        Dim i As Long: i = 0
        For Each keyS In dictPeak.Keys
            i = i + 1: partsS = Split(CStr(keyS), "|"): arrPeaks = dictPeak(keyS)
            outArr(i, 1) = partsS(0): outArr(i, 2) = partsS(1)
            Dim j As Integer: For j = 1 To 7: outArr(i, j + 2) = PicoCellText(arrPeaks, j): Next j
        Next keyS
        wsOut.Range("A2").Resize(dictPeak.Count, 9).Value2 = outArr
    End If
    wsOut.Columns("A:I").AutoFit
End Sub

Private Function PicoCellText(ByVal arrPeaks As Variant, ByVal wd As Integer) As String
    Dim fte As Double: fte = CDbl(arrPeaks(wd, 1))
    If fte <= 0# Then PicoCellText = "" Else PicoCellText = arrPeaks(wd, 2) & " (" & CStr(Round(fte, 2)) & ")"
End Function

Private Function InitPeaksArray() As Variant
    Dim a(1 To 7, 1 To 2) As Variant, i As Integer: For i = 1 To 7: a(i, 1) = 0#: a(i, 2) = "": Next i: InitPeaksArray = a
End Function

Private Function NombreDia(ByVal wd As Integer) As String
    NombreDia = Choose(wd, "Lunes", "Martes", "Miércoles", "Jueves", "Viernes", "Sábado", "Domingo")
End Function

Private Function FloorToHalfHourDbl(ByVal d As Double) As Double
    Dim mins As Long: mins = CLng(((d - Fix(d)) * 1440#) + 0.0000001)
    mins = (mins \ 30) * 30: FloorToHalfHourDbl = Fix(d) + (mins / 1440#)
End Function

Private Function TimeLabel(ByVal d As Double) As String
    Dim tm As Long: tm = CLng(((d - Fix(d)) * 1440#) + 0.0000001)
    TimeLabel = Format(tm \ 60, "00") & ":" & Format(tm Mod 60, "00")
End Function

Private Function MinDbl(ByVal a As Double, ByVal b As Double) As Double: If a < b Then MinDbl = a Else MinDbl = b: End Function
Private Function MaxDbl(ByVal a As Double, ByVal b As Double) As Double: If a > b Then MaxDbl = a Else MaxDbl = b: End Function

Private Function GetOrCreateSheet(ByVal name As String) As Worksheet
    On Error Resume Next: Set GetOrCreateSheet = ThisWorkbook.Worksheets(name): On Error GoTo 0
    If GetOrCreateSheet Is Nothing Then
        Set GetOrCreateSheet = ThisWorkbook.Worksheets.Add(After:=ThisWorkbook.Worksheets(ThisWorkbook.Worksheets.Count))
        GetOrCreateSheet.name = name
    End If
End Function
