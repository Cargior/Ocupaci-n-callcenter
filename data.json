Gemini ha dicho
¡Entiendo! El error de sintaxis que ves en la imagen (líneas en azul/rojo de fondo) ocurre porque algunas funciones cortas de comparación (MinDbl y MaxDbl) quedaron escritas en una sola línea de una forma que el editor de VBA no siempre acepta, dependiendo de la versión.

Para solucionar esto de forma definitiva, he reescrito esas funciones con la estructura completa de bloque (usando If... Then... Else... End If en líneas separadas).

Aquí tienes el código completo, corregido y listo para usar:

VBA
Option Explicit

'============================================================
' MACRO UNIFICADA DE OCUPACIÓN HISTÓRICA - VERSIÓN FINAL
'============================================================
Public Sub Procesar_Export()

    Dim wsExp As Worksheet, wsSrv As Worksheet, wsNom As Worksheet
    Dim ultExp As Long, ultSrv As Long, ultNom As Long
    Dim dictSrv As Object, dictNom As Object
    Dim i As Long
    Dim vag As Variant, legajo As Variant
    Dim texto As String
    Dim ini As Long, fin As Long
    Dim valMod As String, fechaLogueo As Variant, mesLogueo As String
    Dim claveBusqueda As String

    Set wsExp = ThisWorkbook.Worksheets("Export")
    Set wsSrv = ThisWorkbook.Worksheets("Servicio")
    Set wsNom = ThisWorkbook.Worksheets("Nomina")

    Set dictSrv = CreateObject("Scripting.Dictionary")
    Set dictNom = CreateObject("Scripting.Dictionary")
    dictSrv.CompareMode = vbTextCompare
    dictNom.CompareMode = vbTextCompare

    Application.ScreenUpdating = False
    Application.EnableEvents = False
    Application.Calculation = xlCalculationManual

    '---------------------------------------------------------
    ' Cargar tabla Servicio (VAG -> Cliente, Campaña, Servicio)
    '---------------------------------------------------------
    ultSrv = wsSrv.Cells(wsSrv.Rows.Count, "A").End(xlUp).Row
    If ultSrv >= 2 Then
        For i = 2 To ultSrv
            vag = wsSrv.Cells(i, "A").Value
            If Len(vag) > 0 Then
                dictSrv(CStr(vag)) = Array( _
                    wsSrv.Cells(i, "B").Value, _
                    wsSrv.Cells(i, "C").Value, _
                    wsSrv.Cells(i, "D").Value _
                )
            End If
        Next i
    End If

    '---------------------------------------------------------
    ' Cargar tabla Nomina (Legajo + Mes -> Presencialidad)
    '---------------------------------------------------------
    ultNom = wsNom.Cells(wsNom.Rows.Count, "A").End(xlUp).Row
    If ultNom >= 2 Then
        For i = 2 To ultNom
            legajo = Trim$(CStr(wsNom.Cells(i, "A").Value))
            Dim mesNomina As String
            mesNomina = Trim$(CStr(wsNom.Cells(i, "C").Value))
            
