Private Function FloorToHalfHourDbl(ByVal d As Double) As Double

    Dim mins As Long

    mins = CLng(((d - Fix(d)) * 1440#) + 0.0000001)

    mins = (mins \ 30) * 30

    FloorToHalfHourDbl = Fix(d) + (mins / 1440#)

End Function



Private Function MinDbl(ByVal a As Double, ByVal b As Double) As Double

    If a < b Then MinDbl = a Else MinDbl = b

End Function



Private Function MaxDbl(ByVal a As Double, ByVal b As Double) As Double

    If a > b Then MaxDbl = a Else MaxDbl = b

End Function



Private Function TimeLabel(ByVal d As Double) As String

    Dim totalM As Long, hh As Long, mm As Long

    totalM = CLng(((d - Fix(d)) * 1440#) + 0.0000001)

    hh = totalM \ 60

    mm = totalM Mod 60

    TimeLabel = Right$("0" & CStr(hh), 2) & ":" & Right$("0" & CStr(mm), 2)

End Function



