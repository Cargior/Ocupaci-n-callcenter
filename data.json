Option Explicit



'============================================================

' MACRO PRINCIPAL

'  PASO 1: Legajo desde B -> E (entre paréntesis)

'  PASO 2: Por VAG (A) -> Cliente/Campaña/Servicio a G/H/I

'  PASO 3: Por Legajo (E) -> Presencialidad a F (HIBRIDO=>PRESENCIAL, default PRESENCIAL)

'  PASO 4: Ocupación por franja 30m -> Ocup_PRESENCIAL y Ocup_TELETRABAJO

'  PASO 5: Informe SIMPLE (SOLO PRESENCIAL)

'       Filas: Campaña + Subcampaña

'       Columnas: Lunes..Domingo

'       Celda: "Franja pico (FTE)"  (FTE redondeado a 0 dec)

'  PASO 6 (MOD): "Max Ocupación x Franja" (SOLO PRESENCIAL)

'       Max FTE por CLIENTE + Campaña + Subcampaña + DíaSemana + Franja

'============================================================

Public Sub Procesar_Export()



    Dim wsExp As Worksheet, wsSrv As Worksheet, wsNom As Worksheet

    Dim ultExp As Long, ultSrv As Long, ultNom As Long

    Dim dictSrv As Object, dictNom As Object

    Dim i As Long

    Dim vag As Variant, legajo As Variant

    Dim texto As String

    Dim ini As Long, fin As Long

    Dim valMod As String



    Set wsExp = ThisWorkbook.Worksheets("Export")

    Set wsSrv = ThisWorkbook.Worksheets("Servicio")

    Set wsNom = ThisWorkbook.Worksheets("Nomina")



    Set dictSrv = CreateObject("Scripting.Dictionary")

    Set dictNom = CreateObject("Scripting.Dictionary")

    dictSrv.CompareMode = vbTextCompare

    dictNom.CompareMode = vbTextCompare



    Application.ScreenUpdating = False

    Application.EnableEvents = False

    Application.Calculation = xlCalculationManual



    '-------------------------

    ' Cargar tabla Servicio (VAG -> Cliente, Campaña, Servicio)

    '-------------------------

    ultSrv = wsSrv.Cells(wsSrv.Rows.Count, "A").End(xlUp).Row

    If ultSrv >= 2 Then

        For i = 2 To ultSrv

            vag = wsSrv.Cells(i, "A").Value

            If Len(vag) > 0 Then

                dictSrv(CStr(vag)) = Array( _

                    wsSrv.Cells(i, "B").Value, _

                    wsSrv.Cells(i, "C").Value, _

                    wsSrv.Cells(i, "D").Value _

                )

            End If

        Next i

    End If



    '-------------------------

    ' Cargar tabla Nomina (Legajo -> Presencialidad)

    '-------------------------

    ultNom = wsNom.Cells(wsNom.Rows.Count, "A").End(xlUp).Row

    If ultNom >= 2 Then

        For i = 2 To ultNom

            legajo = wsNom.Cells(i, "A").Value

            If Len(legajo) > 0 Then

                dictNom(CStr(legajo)) = wsNom.Cells(i, "B").Value

            End If

        Next i

    End If



    '-------------------------

    ' Recorrer Export

    '-------------------------

    ultExp = wsExp.Cells(wsExp.Rows.Count, "A").End(xlUp).Row

    If ultExp < 2 Then GoTo Salida



    For i = 2 To ultExp



        'PASO 1: Legajo desde B -> E

        texto = wsExp.Cells(i, "B").Value

        ini = InStr(texto, "(")

        fin = InStr(texto, ")")

        If ini > 0 And fin > ini Then

            wsExp.Cells(i, "E").Value = Mid$(texto, ini + 1, fin - ini - 1)

        Else

            wsExp.Cells(i, "E").ClearContents

        End If



        'PASO 2: Por VAG (A) -> G/H/I

        vag = wsExp.Cells(i, "A").Value

        If Len(vag) > 0 And dictSrv.Exists(CStr(vag)) Then

            wsExp.Cells(i, "G").Value = dictSrv(CStr(vag))(0) 'Cliente

            wsExp.Cells(i, "H").Value = dictSrv(CStr(vag))(1) 'Campaña

            wsExp.Cells(i, "I").Value = dictSrv(CStr(vag))(2) 'Servicio (Subcampaña)

        Else

            wsExp.Cells(i, "G").ClearContents

            wsExp.Cells(i, "H").ClearContents

            wsExp.Cells(i, "I").ClearContents

        End If



        'PASO 3: Presencialidad a F (default PRESENCIAL)

        legajo = wsExp.Cells(i, "E").Value

        If Len(legajo) > 0 And dictNom.Exists(CStr(legajo)) Then

            valMod = Trim$(CStr(dictNom(CStr(legajo))))

            If UCase$(valMod) = "HIBRIDO" Then valMod = "PRESENCIAL"

            wsExp.Cells(i, "F").Value = valMod

        Else

            wsExp.Cells(i, "F").Value = "PRESENCIAL"

        End If



    Next i



    'PASO 4: Ocupación por franja 30m

    GenerarOcupacionTiempo_Chunked_OnePass wsExp, ultExp, 200000, "Ocup_PRESENCIAL", "Ocup_TELETRABAJO"



    'PASO 5: Informe simple (solo presencial) - pico por DOW

    GenerarHojaInforme_Simple_Picos_Presencial



    'PASO 6 (MOD): Max por franja por DOW (solo presencial) + CLIENTE

    GenerarHojaMaxOcupacionPorFranja_Presencial



Salida:

    Application.Calculation = xlCalculationAutomatic

    Application.EnableEvents = True

    Application.ScreenUpdating = True



End Sub





'============================================================

' PASO 4: Ocup_* por franja 30m sumando tiempo

'============================================================

Private Sub GenerarOcupacionTiempo_Chunked_OnePass(ByVal wsExp As Worksheet, ByVal lastExp As Long, _

                                                  ByVal chunkSize As Long, _

                                                  ByVal outPres As String, ByVal outTele As String)



    Dim dictPres As Object, dictTele As Object, dictUse As Object

    Dim startRow As Long, endRow As Long

    Dim data As Variant

    Dim r As Long



    Dim modVal As String, modUP As String

    Dim cliente As String, camp As String, subcamp As String



    Dim dtIn As Double, dtOut As Double

    Dim slotStart As Double, slotEnd As Double

    Dim overlap As Double, mins As Double



    Dim dayKey As String, frLabel As String, k As String



    Set dictPres = CreateObject("Scripting.Dictionary")

    Set dictTele = CreateObject("Scripting.Dictionary")

    dictPres.CompareMode = vbTextCompare

    dictTele.CompareMode = vbTextCompare



    Const HALF_HOUR As Double = 2.08333333333333E-02 '30/1440

    Const DAY_MINUTES As Double = 1440#



    startRow = 2



    Do While startRow <= lastExp

        endRow = startRow + chunkSize - 1

        If endRow > lastExp Then endRow = lastExp



        data = wsExp.Range("A" & startRow & ":I" & endRow).Value2



        For r = 1 To UBound(data, 1)



            'Modalidad: F (col 6 dentro de A:I)

            modVal = Trim$(CStr(data(r, 6)))

            modUP = UCase$(modVal)



            If modUP = "PRESENCIAL" Then

                Set dictUse = dictPres

            ElseIf modUP = "TELETRABAJO" Then

                Set dictUse = dictTele

            Else

                GoTo NextR

            End If



            'Ingreso/Egreso: C/D (3/4 dentro de A:I)

            If IsEmpty(data(r, 3)) Or IsEmpty(data(r, 4)) Then GoTo NextR

            If Not IsNumeric(data(r, 3)) Or Not IsNumeric(data(r, 4)) Then GoTo NextR



            dtIn = CDbl(data(r, 3))

            dtOut = CDbl(data(r, 4))



            'Cruce medianoche

            If dtOut < dtIn Then dtOut = dtOut + 1#



            'Dimensiones: G/H/I (7/8/9 dentro de A:I)

            cliente = Trim$(CStr(data(r, 7)))

            camp = Trim$(CStr(data(r, 8)))

            subcamp = Trim$(CStr(data(r, 9))) 'Servicio como "Subcampaña"



            If Len(cliente) = 0 Then cliente = "(Sin cliente)"

            If Len(camp) = 0 Then camp = "(Sin campaña)"

            If Len(subcamp) = 0 Then subcamp = "(Sin subcampaña)"



            slotStart = FloorToHalfHourDbl(dtIn)



            Do While slotStart < dtOut

                slotEnd = slotStart + HALF_HOUR



                overlap = MinDbl(dtOut, slotEnd) - MaxDbl(dtIn, slotStart)

                If overlap > 0# Then

                    mins = overlap * DAY_MINUTES



                    dayKey = CStr(Fix(slotStart))

                    frLabel = TimeLabel(slotStart) & "-" & TimeLabel(slotEnd)



                    k = cliente & "|" & camp & "|" & subcamp & "|" & dayKey & "|" & frLabel



                    If dictUse.Exists(k) Then

                        dictUse(k) = dictUse(k) + mins

                    Else

                        dictUse.Add k, mins

                    End If

                End If



                slotStart = slotEnd

            Loop



NextR:

        Next r



        startRow = endRow + 1

    Loop



    WriteDictTiempo_Optim dictPres, GetOrCreateSheet(outPres)

    WriteDictTiempo_Optim dictTele, GetOrCreateSheet(outTele)



End Sub





'============================================================

' OUTPUT: Ocup_PRESENCIAL / Ocup_TELETRABAJO

'============================================================

Private Sub WriteDictTiempo_Optim(ByVal dict As Object, ByVal wsOut As Worksheet)

    Dim arr() As Variant, parts() As String

    Dim i As Long, k As Variant

    Dim mins As Double



    wsOut.Cells.Clear

    wsOut.Range("A1:H1").Value = Array("Cliente", "Campaña", "Subcampaña", "Día", "Franja", "Minutos", "Horas", "FTE")



    If dict.Count = 0 Then Exit Sub



    ReDim arr(1 To dict.Count, 1 To 8)



    i = 0

    For Each k In dict.Keys

        i = i + 1

        parts = Split(CStr(k), "|")



        mins = CDbl(dict(k))



        arr(i, 1) = parts(0)

        arr(i, 2) = parts(1)

        arr(i, 3) = parts(2)

        arr(i, 4) = CDate(CDbl(parts(3)))

        arr(i, 5) = parts(4)

        arr(i, 6) = Round(mins, 2)

        arr(i, 7) = Round(mins / 60#, 4)

        arr(i, 8) = Round(mins / 30#, 0) 'FTE (franja 30m)

    Next k



    wsOut.Range("A2").Resize(dict.Count, 8).Value2 = arr

    wsOut.Columns("D").NumberFormat = "dd/mm/yyyy"

    wsOut.Columns("F").NumberFormat = "0.00"

    wsOut.Columns("G").NumberFormat = "0.0000"

    wsOut.Columns("H").NumberFormat = "0"

    wsOut.Columns("A:H").AutoFit

End Sub





'============================================================

' PASO 5: INFORME SIMPLE (SOLO PRESENCIAL) - pico por día de semana

'============================================================

Private Sub GenerarHojaInforme_Simple_Picos_Presencial()



    Dim wsOut As Worksheet

    Set wsOut = GetOrCreateSheet("Informe")

    wsOut.Cells.Clear



    wsOut.Range("A1:I1").Value = Array("Campaña", "Subcampaña", "Lunes", "Martes", "Miércoles", "Jueves", "Viernes", "Sábado", "Domingo")



    Dim wsSrc As Worksheet

    On Error Resume Next

    Set wsSrc = ThisWorkbook.Worksheets("Ocup_PRESENCIAL")

    On Error GoTo 0



    If wsSrc Is Nothing Then

        wsOut.Cells(2, 1).Value = "(No existe la hoja Ocup_PRESENCIAL)"

        Exit Sub

    End If



    Dim lastRow As Long

    lastRow = wsSrc.Cells(wsSrc.Rows.Count, "A").End(xlUp).Row

    If lastRow < 2 Then

        wsOut.Cells(2, 1).Value = "(Sin datos en Ocup_PRESENCIAL)"

        Exit Sub

    End If



    Dim data As Variant

    data = wsSrc.Range("A2:H" & lastRow).Value2



    Dim dictMaxSlot As Object

    Set dictMaxSlot = CreateObject("Scripting.Dictionary")

    dictMaxSlot.CompareMode = vbTextCompare



    Dim r As Long

    Dim camp As String, subcamp As String, franja As String

    Dim dayDbl As Double, d As Date, wd As Integer

    Dim fte As Double

    Dim keySlot As String



    'Max por (Camp|Sub|wd|franja)

    For r = 1 To UBound(data, 1)



        camp = Trim$(CStr(data(r, 2)))

        subcamp = Trim$(CStr(data(r, 3)))

        franja = Trim$(CStr(data(r, 5)))



        If Len(camp) = 0 Then camp = "(Sin campaña)"

        If Len(subcamp) = 0 Then subcamp = "(Sin subcampaña)"

        If Len(franja) = 0 Then GoTo NextR



        If Not IsNumeric(data(r, 4)) Then GoTo NextR

        dayDbl = CDbl(data(r, 4))

        d = CDate(dayDbl)

        wd = VBA.Weekday(d, vbMonday) 'Lun=1..Dom=7



        If Not IsNumeric(data(r, 8)) Then GoTo NextR

        fte = CDbl(data(r, 8))



        keySlot = camp & "|" & subcamp & "|" & CStr(wd) & "|" & franja



        If dictMaxSlot.Exists(keySlot) Then

            If fte > CDbl(dictMaxSlot(keySlot)) Then dictMaxSlot(keySlot) = fte

        Else

            dictMaxSlot.Add keySlot, fte

        End If



NextR:

    Next r



    If dictMaxSlot.Count = 0 Then

        wsOut.Cells(2, 1).Value = "(Sin resultados)"

        Exit Sub

    End If



    'Picos por (Camp|Sub) y wd

    Dim dictPeak As Object

    Set dictPeak = CreateObject("Scripting.Dictionary")

    dictPeak.CompareMode = vbTextCompare



    Dim k As Variant, parts() As String

    Dim keySvc As String

    Dim arrPeaks As Variant



    For Each k In dictMaxSlot.Keys

        parts = Split(CStr(k), "|")

        camp = parts(0)

        subcamp = parts(1)

        wd = CInt(parts(2))

        franja = parts(3)

        fte = CDbl(dictMaxSlot(k))



        keySvc = camp & "|" & subcamp



        If dictPeak.Exists(keySvc) Then

            arrPeaks = dictPeak(keySvc)

        Else

            arrPeaks = InitPeaksArray()

        End If



        If fte > CDbl(arrPeaks(wd, 1)) Then

            arrPeaks(wd, 1) = fte

            arrPeaks(wd, 2) = franja

        End If



        dictPeak(keySvc) = arrPeaks

    Next k



    'Volcar matriz

    Dim outArr() As Variant

    ReDim outArr(1 To dictPeak.Count, 1 To 9)



    Dim i As Long

    i = 0



    For Each k In dictPeak.Keys

        i = i + 1

        parts = Split(CStr(k), "|")

        camp = parts(0)

        subcamp = parts(1)

        arrPeaks = dictPeak(k)



        outArr(i, 1) = camp

        outArr(i, 2) = subcamp



        outArr(i, 3) = PicoCellText(arrPeaks, 1)

        outArr(i, 4) = PicoCellText(arrPeaks, 2)

        outArr(i, 5) = PicoCellText(arrPeaks, 3)

        outArr(i, 6) = PicoCellText(arrPeaks, 4)

        outArr(i, 7) = PicoCellText(arrPeaks, 5)

        outArr(i, 8) = PicoCellText(arrPeaks, 6)

        outArr(i, 9) = PicoCellText(arrPeaks, 7)

    Next k



    wsOut.Range("A2").Resize(dictPeak.Count, 9).Value2 = outArr



    'Formato legible

    With wsOut

        .Rows(1).Font.Bold = True

        .Range("A1:I1").Interior.ColorIndex = 15

        .Columns("A:B").ColumnWidth = 28

        .Columns("C:I").ColumnWidth = 20

        .Columns("C:I").HorizontalAlignment = xlCenter

        .Columns("C:I").WrapText = True

        .Range("A1:I" & (dictPeak.Count + 1)).Borders.LineStyle = xlContinuous

        .Rows(1).WrapText = True

    End With



    SortInformeCampSub wsOut, wsOut.Range(wsOut.Cells(2, 1), wsOut.Cells(dictPeak.Count + 1, 9))



End Sub





'============================================================

' PASO 6 (MOD): MAX OCUPACIÓN POR FRANJA (SOLO PRESENCIAL)

'  Fuente: Ocup_PRESENCIAL

'  Devuelve: Max FTE por CLIENTE + Campaña + Subcampaña + DíaSemana + Franja

'============================================================

Private Sub GenerarHojaMaxOcupacionPorFranja_Presencial()



    Dim wsOut As Worksheet

    Set wsOut = GetOrCreateSheet("Max Ocupación x Franja")

    wsOut.Cells.Clear



    'Agrego Cliente (desde Ocup_PRESENCIAL col A) y DíaNum para ordenar Lun..Dom

    wsOut.Range("A1:G1").Value = Array("Cliente", "Campaña", "Subcampaña", "DíaNum", "Día", "Franja", "Max FTE (Pres)")



    Dim wsSrc As Worksheet

    On Error Resume Next

    Set wsSrc = ThisWorkbook.Worksheets("Ocup_PRESENCIAL")

    On Error GoTo 0



    If wsSrc Is Nothing Then

        wsOut.Cells(2, 1).Value = "(No existe la hoja Ocup_PRESENCIAL)"

        Exit Sub

    End If



    Dim lastRow As Long

    lastRow = wsSrc.Cells(wsSrc.Rows.Count, "A").End(xlUp).Row

    If lastRow < 2 Then

        wsOut.Cells(2, 1).Value = "(Sin datos en Ocup_PRESENCIAL)"

        Exit Sub

    End If



    Dim data As Variant

    data = wsSrc.Range("A2:H" & lastRow).Value2

    'A Cliente (1), B Campaña (2), C Subcampaña (3), D Día (4), E Franja (5), H FTE (8)



    Dim dict As Object

    Set dict = CreateObject("Scripting.Dictionary")

    dict.CompareMode = vbTextCompare



    Dim r As Long

    Dim cliente As String, camp As String, subcamp As String, franja As String

    Dim dayDbl As Double, d As Date, wd As Integer

    Dim fte As Double

    Dim key As String



    For r = 1 To UBound(data, 1)



        cliente = Trim$(CStr(data(r, 1)))

        camp = Trim$(CStr(data(r, 2)))

        subcamp = Trim$(CStr(data(r, 3)))

        franja = Trim$(CStr(data(r, 5)))



        If Len(cliente) = 0 Then cliente = "(Sin cliente)"

        If Len(camp) = 0 Then camp = "(Sin campaña)"

        If Len(subcamp) = 0 Then subcamp = "(Sin subcampaña)"

        If Len(franja) = 0 Then GoTo NextR



        'Día -> weekday (Lun=1..Dom=7)

        If Not IsNumeric(data(r, 4)) Then GoTo NextR

        dayDbl = CDbl(data(r, 4))

        d = CDate(dayDbl)

        wd = VBA.Weekday(d, vbMonday)



        If Not IsNumeric(data(r, 8)) Then GoTo NextR

        fte = CDbl(data(r, 8))



        'Clave ahora incluye Cliente

        key = cliente & "|" & camp & "|" & subcamp & "|" & CStr(wd) & "|" & franja



        If dict.Exists(key) Then

            If fte > CDbl(dict(key)) Then dict(key) = fte

        Else

            dict.Add key, fte

        End If



NextR:

    Next r



    If dict.Count = 0 Then

        wsOut.Cells(2, 1).Value = "(Sin resultados)"

        Exit Sub

    End If



    Dim outArr() As Variant, parts() As String

    Dim i As Long, k As Variant

    ReDim outArr(1 To dict.Count, 1 To 7)



    i = 0

    For Each k In dict.Keys

        i = i + 1

        parts = Split(CStr(k), "|")



        outArr(i, 1) = parts(0)                  'Cliente

        outArr(i, 2) = parts(1)                  'Campaña

        outArr(i, 3) = parts(2)                  'Subcampaña

        outArr(i, 4) = CInt(parts(3))            'DíaNum

        outArr(i, 5) = NombreDia(CInt(parts(3))) 'Día

        outArr(i, 6) = parts(4)                  'Franja

        outArr(i, 7) = Round(CDbl(dict(k)), 0)   'Max FTE entero

    Next k



    wsOut.Range("A2").Resize(dict.Count, 7).Value2 = outArr



    With wsOut

        .Rows(1).Font.Bold = True

        .Range("A1:G1").Interior.ColorIndex = 15

        .Columns("A:C").ColumnWidth = 28

        .Columns("D").ColumnWidth = 8

        .Columns("E").ColumnWidth = 12

        .Columns("F").ColumnWidth = 14

        .Columns("G").ColumnWidth = 16

        .Columns("D:G").HorizontalAlignment = xlCenter

        .Range("A1:G" & (dict.Count + 1)).Borders.LineStyle = xlContinuous

        .Columns("A:G").AutoFit

        .Columns("D").Hidden = True 'oculto DíaNum para que quede prolijo

    End With



    SortMaxFranja_Cliente_DOW wsOut, wsOut.Range(wsOut.Cells(2, 1), wsOut.Cells(dict.Count + 1, 7))



End Sub





'======================

' Helpers Informe

'======================

Private Function InitPeaksArray() As Variant

    Dim a(1 To 7, 1 To 2) As Variant

    Dim i As Integer

    For i = 1 To 7

        a(i, 1) = 0#   'peakFTE

        a(i, 2) = ""   'peakFranja

    Next i

    InitPeaksArray = a

End Function



Private Function PicoCellText(ByVal arrPeaks As Variant, ByVal wd As Integer) As String

    Dim fte As Double, fr As String

    fte = CDbl(arrPeaks(wd, 1))

    fr = CStr(arrPeaks(wd, 2))

    If Len(fr) = 0 Or fte <= 0# Then

        PicoCellText = ""

    Else

