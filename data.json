        ini = InStr(texto, "(")
        fin = InStr(texto, ")")
        If ini > 0 And fin > ini Then
            wsExp.Cells(i, "E").Value = Mid$(texto, ini + 1, fin - ini - 1)
        Else
            wsExp.Cells(i, "E").ClearContents
        End If

        vag = wsExp.Cells(i, "A").Value
        If Len(vag) > 0 And dictSrv.Exists(CStr(vag)) Then
            wsExp.Cells(i, "G").Value = dictSrv(CStr(vag))(0) 
            wsExp.Cells(i, "H").Value = dictSrv(CStr(vag))(1) 
            wsExp.Cells(i, "I").Value = dictSrv(CStr(vag))(2) 
        Else
            wsExp.Cells(i, "G").ClearContents
            wsExp.Cells(i, "H").ClearContents
            wsExp.Cells(i, "I").ClearContents
        End If

        legajo = Trim$(CStr(wsExp.Cells(i, "E").Value))
        fechaLogueo = wsExp.Cells(i, "C").Value
        
        If Len(legajo) > 0 And IsDate(fechaLogueo) Then
