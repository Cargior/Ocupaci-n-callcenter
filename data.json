<body>

<div class="shell" id="shell" style="display:none">
  <nav class="sidebar">
    <div class="brand"><div class="brand-title">Workforce Histórico</div></div>
    <div class="nav-item active" onclick="nav('kpis',this)">Resumen ejecutivo</div>
    <div class="nav-item" onclick="nav('daily',this)">Ocupación diaria</div>
    <div class="nav-item" onclick="nav('clients',this)">Por cliente</div>
  </nav>

  <main class="main">
    <div class="period-bar">
      <label>Desde</label>
      <input type="date" class="date-input" id="date-from" onchange="onDateChange()">
      <label>Hasta</label>
      <input type="date" class="date-input" id="date-to" onchange="onDateChange()">
      <span id="period-info" style="font-size:12px;color:var(--m)"></span>
    </div>

    <div class="section active" id="sec-kpis">
      <div class="kpi-grid">
        <div class="kpi" style="border-top:2px solid var(--g)"><div style="font-size:10px;color:var(--m)">POSICIONES ASIGNADAS</div><div class="kv" id="k-pos">-</div></div>
        <div class="kpi" style="border-top:2px solid var(--bl)"><div style="font-size:10px;color:var(--m)">OCC. PROMEDIO</div><div class="kv" id="k-occ">-</div></div>
        <div class="kpi" style="border-top:2px solid var(--a)"><div style="font-size:10px;color:var(--m)">PICO MÁXIMO</div><div class="kv" id="k-max">-</div></div>
        <div class="kpi" style="border-top:2px solid var(--r)"><div style="font-size:10px;color:var(--m)">DÍA PICO</div><div class="kv" id="k-mf" style="font-size:18px">-</div></div>
      </div>

      <div class="free-card">
        <div style="margin-bottom:16px;font-weight:600">OCUPACIÓN POR PISO (DÍA PICO DEL PERIODO)</div>
        <div id="piso-rows"></div>
      </div>

      <div class="cc">
        <div style="margin-bottom:14px;font-size:11px;color:var(--m)">USADAS VS LIBRES POR PISO</div>
        <div style="height:250px"><canvas id="ch-piso"></canvas></div>
      </div>
    </div>

    <div class="section" id="sec-daily">
      <div class="cc">
        <div style="margin-bottom:14px;font-size:11px;color:var(--m)">EVOLUCIÓN DE OCUPACIÓN (FTE DECIMAL)</div>
        <div style="height:350px"><canvas id="ch-daily"></canvas></div>
      </div>
    </div>

    <div class="section" id="sec-clients">
      <div class="cc">
        <table class="dt" id="tbl-cli"></table>
      </div>
    </div>
  </main>
</div>

<div id="loading" class="loading">Cargando base de datos...</div>

<script>
let RAW=null, dateFrom='', dateTo='', charts={};

const oc = v => v<=80?'#22c98a':v<=100?'#f5a623':'#e05252';

async function init(){
  try{
    const res = await fetch('data.json');
    RAW = await res.json();
    const dates = RAW.daily.map(d=>d.Fecha).sort();
    dateFrom = dates[0]; 
    dateTo = dates[dates.length-1];
    document.getElementById('date-from').value = dateFrom;
    document.getElementById('date-to').value = dateTo;
    document.getElementById('loading').style.display='none';
    document.getElementById('shell').style.display='grid';
    render();
  }catch(e){ document.getElementById('loading').textContent='Error al cargar data.json'; }
}

function onDateChange(){
  dateFrom = document.getElementById('date-from').value;
  dateTo = document.getElementById('date-to').value;
  render();
}

function render(){
  const data = RAW.daily.filter(d => d.Fecha >= dateFrom && d.Fecha <= dateTo);
  const asigMap = RAW.meta.asigMap;
  const totalPos = RAW.meta.total_pos;

  const lab = data.filter(d => d.dow > 0 && d.dow < 6);
  const labAvg = lab.length ? (lab.reduce((s,d)=>s+d.occ_pct,0)/lab.length).toFixed(1) : 0;
  const maxOcc = lab.length ? Math.max(...lab.map(d=>d.occ_pct)) : 0;
  const maxDay = lab.find(d=>d.occ_pct === maxOcc)?.Fecha || '-';

  document.getElementById('k-pos').textContent = totalPos;
  document.getElementById('k-occ').textContent = labAvg + '%';
  document.getElementById('k-max').textContent = maxOcc + '%';
  document.getElementById('k-mf').textContent = maxDay;

  // Calculo de pisos basado en día pico con DECIMALES
  const peakCli = (maxDay !== '-' && RAW.daily_per_client[maxDay]) ? RAW.daily_per_client[maxDay] : {};
  const pisoStats = {};
  
  for(const [cli, info] of Object.entries(asigMap)){
    const p = info.piso;
    if(!pisoStats[p]) pisoStats[p] = {used: 0, total: 0};
    pisoStats[p].total += info.pos;
    pisoStats[p].used += Math.min(parseFloat(peakCli[cli] || 0), info.pos);
  }

  const prows = document.getElementById('piso-rows'); prows.innerHTML = '';
  Object.entries(pisoStats).forEach(([p, s]) => {
    const pct = (s.used/s.total*100).toFixed(1);
    prows.innerHTML += `
      <div class="prow">
        <span>Piso ${p}</span>
        <div class="btrack"><div class="bfill" style="width:${pct}%;background:${oc(pct)}"></div></div>
        <span style="font-family:DM Mono;font-size:11px;text-align:right">${s.used.toFixed(1)} / ${s.total}</span>
      </div>`;
  });

  renderCharts(data, pisoStats);
  renderTable(peakCli, asigMap);
}

function renderCharts(data, pisoStats){
  if(charts.daily) charts.daily.destroy();
  charts.daily = new Chart(document.getElementById('ch-daily'), {
    type:'line',
    data: {
      labels: data.map(d=>d.Fecha),
      datasets: [{
        label: 'Agentes (FTE)',
        data: data.map(d=>d.pico_total),
        borderColor: '#22c98a',
        backgroundColor: 'rgba(34,201,138,0.1)',
        fill: true,
        tension: 0.3
      }]
    },
    options: { responsive: true, maintainAspectRatio: false }
  });

  if(charts.piso) charts.piso.destroy();
  charts.piso = new Chart(document.getElementById('ch-piso'), {
    type:'bar',
    data: {
      labels: Object.keys(pisoStats),
      datasets: [{
        label: 'Ocupados',
        data: Object.values(pisoStats).map(s=>s.used.toFixed(1)),
        backgroundColor: '#22c98a'
      },{
        label: 'Libres',
        data: Object.values(pisoStats).map(s=>(s.total - s.used).toFixed(1)),
        backgroundColor: 'rgba(255,255,255,0.1)'
      }]
    },
    options: { responsive: true, maintainAspectRatio: false, scales: { x:{stacked:true}, y:{stacked:true} } }
  });
}

function renderTable(peakCli, asigMap){
  const tbl = document.getElementById('tbl-cli');
  let html = `<thead><tr><th>Cliente</th><th>Piso</th><th>Asignadas</th><th>Usadas (Peak)</th><th>% Occ</th></tr></thead><tbody>`;
  
  Object.entries(asigMap).sort((a,b)=>b[1].pos - a[1].pos).forEach(([cli, info]) => {
    const used = parseFloat(peakCli[cli] || 0).toFixed(1);
    const pct = (used / info.pos * 100).toFixed(1);
    html += `<tr>
      <td>${cli}</td>
      <td>${info.piso}</td>
      <td>${info.pos}</td>
      <td style="font-family:DM Mono">${used}</td>
      <td><span class="pill ${pct>100?'pr':'pg'}">${pct}%</span></td>
    </tr>`;
  });
  tbl.innerHTML = html + `</tbody>`;
}

function nav(id, el){
  document.querySelectorAll('.section').forEach(s=>s.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  document.getElementById('sec-'+id).classList.add('active');
  el.classList.add('active');
}

init();
</script>
</body>
</html>
¿Qué cambió en este archivo?
Lógica de FTE Decimal: En las funciones render(), renderCharts() y renderTable(), ahora usamos parseFloat() y .toFixed(1). Esto permite que si tenés 45.5 agentes, el gráfico y la tabla lo muestren correctamente.

Día Pico Real: El sistema busca el pico máximo dentro del rango de fechas que elijas. Gracias a que ahora guardamos la fecha en el JSON, el "Día Pico" puede ser cualquiera (ej. el lunes 09/03).

Gráficos de Línea: Cambié el gráfico diario a uno de línea con tensión, que se ve mucho mejor para visualizar tendencias históricas a través de los días.

Mapa de Pisos: El cálculo de barras ahora considera los decimales para determinar cuánto espacio del piso está realmente ocupado.

