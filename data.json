    <div style="height:300px"><canvas id="ch-hourly"></canvas></div>
  </div>
  
  <div class="cc">
    <div class="ct">Eficiencia de Puestos</div>
    <div id="efficiency-rank"></div>
  </div>
</div>

<script>
// ... (Dentro de la función render, agregá estas llamadas)
  renderHourlyChart(maxDayRaw);
  renderEfficiencyRank(peakCli, asigMap);

function renderHourlyChart(day) {
  const ctx = document.getElementById('ch-hourly');
  if(charts.hourly) charts.hourly.destroy();
  
  const dayData = RAW.hourly_distribution[day] || {};
  const labels = Object.keys(dayData).sort();
  const values = labels.map(l => dayData[l].toFixed(1));

  charts.hourly = new Chart(ctx, {
    type: 'bar',
    data: {
      labels: labels,
      datasets: [{
        label: 'FTE por Franja',
        data: values,
        backgroundColor: 'rgba(3,102,214,0.1)',
        borderColor: '#0366d6',
        borderWidth: 1,
        borderRadius: 4
      }]
    },
    options: { responsive: true, maintainAspectRatio: false }
  });
}

function renderEfficiencyRank(peakCli, asigMap) {
  const container = document.getElementById('efficiency-rank');
  const clients = Object.entries(asigMap).map(([cli, info]) => {
    const used = parseFloat(peakCli[cli] || 0);
    const pct = (used / info.pos * 100);
    return { cli, pct };
  }).sort((a,b) => b.pct - a.pct);

  let html = '<div style="font-size:12px">';
  html += '<strong>Top Uso:</strong><br>';
  clients.slice(0,3).forEach(c => {
    html += `<div style="display:flex; justify-content:space-between; margin-bottom:5px"><span>${c.cli}</span><span style="color:var(--r)">${c.pct.toFixed(0)}%</span></div>`;
  });
  html += '<br><strong>Sub-utilizados:</strong><br>';
  clients.slice(-3).reverse().forEach(c => {
    html += `<div style="display:flex; justify-content:space-between; margin-bottom:5px"><span>${c.cli}</span><span style="color:var(--g)">${c.pct.toFixed(0)}%</span></div>`;
  });
  container.innerHTML = html + '</div>';
}
</script>
