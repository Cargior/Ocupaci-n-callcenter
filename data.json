    <div class="nav-item" onclick="nav('clients',this)">🏢 Por cliente</div>
</nav>

<script>
// ... (funciones init y onDateChange iguales) ...

function render(){
  const data = RAW.daily.filter(d => d.Fecha >= dateFrom && d.Fecha <= dateTo);
  const asigMap = RAW.meta.asigMap;
  const totalPos = RAW.meta.total_pos;

  const lab = data.filter(d => d.dow > 0 && d.dow < 6);
  // Se eliminó el cálculo de labAvg para el KPI removido
  const maxOcc = lab.length ? Math.max(...lab.map(d=>d.occ_pct)) : 0;
  const maxDayRaw = lab.find(d=>d.occ_pct === maxOcc)?.Fecha || '-';
  
  // Corrección de visualización de fecha (Día Pico)
  let maxDayDisp = maxDayRaw;
  if(maxDayRaw !== '-') {
      // Forzamos la interpretación de la fecha local para evitar desfases de zona horaria
      const partes = maxDayRaw.split('-');
      const df = new Date(partes[0], partes[1] - 1, partes[2]);
      maxDayDisp = df.toLocaleDateString('es-AR', { day: '2-digit', month: 'long' });
  }

  document.getElementById('k-pos').textContent = totalPos;
  document.getElementById('k-max').textContent = maxOcc + '%';
  document.getElementById('k-mf').textContent = maxDayDisp;
  document.getElementById('period-info').textContent = `Actualizado: ${RAW.meta.updated}`;

  // LÓGICA DE REBALSE PARA PERSONAL (PISO 3 Y 4)
  const peakCli = (maxDayRaw !== '-' && RAW.daily_per_client[maxDayRaw]) ? RAW.daily_per_client[maxDayRaw] : {};
  const pisoStats = {};
  
  // Variables para manejar el excedente de Personal
  let fteP3 = parseFloat(peakCli["PERSONAL 3"] || 0);
  let fteP4 = parseFloat(peakCli["PERSONAL 4"] || 0);
  const capP3 = asigMap["PERSONAL 3"]?.pos || 213;
  const capP4 = asigMap["PERSONAL 4"]?.pos || 152;

  let excedenteP3 = Math.max(0, fteP3 - capP3);
  let excedenteP4 = Math.max(0, fteP4 - capP4);

  // Ajuste de valores: el piso origen se clava en su capacidad, el destino suma el excedente
  let fteP3Final = Math.min(fteP3, capP3) + excedenteP4;
  let fteP4Final = Math.min(fteP4, capP4) + excedenteP3;

  for(const [cli, info] of Object.entries(asigMap)){
    const p = info.piso;
    if(!pisoStats[p]) pisoStats[p] = {used: 0, total: 0};
    pisoStats[p].total += info.pos;

    let valorUsar = parseFloat(peakCli[cli] || 0);
    
    // Aplicar lógica especial solo a Personal
    if(cli === "PERSONAL 3") valorUsar = fteP3Final;
    if(cli === "PERSONAL 4") valorUsar = fteP4Final;

    pisoStats[p].used += valorUsar;
  }

  // Renderizado de filas de piso y tablas
  const prows = document.getElementById('piso-rows'); prows.innerHTML = '';
  Object.entries(pisoStats).sort((a,b)=>a[0].localeCompare(b[0])).forEach(([p, s]) => {
    const pct = (s.used/s.total*100).toFixed(1);
    prows.innerHTML += `
      <div class="prow">
        <span class="pname">Piso ${p}</span>
        <div class="btrack"><div class="bfill" style="width:${Math.min(pct, 100)}%;background:${oc(pct)}"></div></div>
        <span class="pstat">${s.used.toFixed(1)} / ${s.total}</span>
      </div>`;
  });

  renderCharts(data, pisoStats);
  renderTable(peakCli, asigMap, fteP3Final, fteP4Final);
}

function renderTable(peakCli, asigMap, f3, f4){
  const tbl = document.getElementById('tbl-cli');
  let html = `<thead><tr><th>Cliente</th><th>Piso</th><th>Pos. Asignadas</th><th>Usadas (Peak)</th><th>Estado</th></tr></thead><tbody>`;
  
  Object.entries(asigMap).sort((a,b)=>b[1].pos - a[1].pos).forEach(([cli, info]) => {
    let used = parseFloat(peakCli[cli] || 0);
    if(cli === "PERSONAL 3") used = f3;
    if(cli === "PERSONAL 4") used = f4;

    const pos = info.pos;
    const pct = pos > 0 ? (used / pos * 100).toFixed(1) : 0;
    let pillClass = pct > 100 ? 'pr' : (pct > 90 ? 'pa' : 'pg');

    html += `<tr>
      <td style="font-weight:600">${cli}</td>
      <td style="color:var(--m)">${info.piso}</td>
      <td style="font-family:Roboto Mono">${pos}</td>
      <td style="font-family:Roboto Mono; font-weight:600; color:var(--bl)">${used.toFixed(1)}</td>
      <td><span class="pill ${pillClass}">${pct}%</span></td>
    </tr>`;
  });
  tbl.innerHTML = html + `</tbody>`;
}
// ... (resto del script igual) ...
</script>
Notas sobre los cambios:
Día Pico: He corregido la forma en que se procesa la fecha YYYY-MM-DD. Al usar .split('-') evitamos que el navegador crea que es UTC y te reste un día (razón por la cual te mostraba febrero siendo marzo).

Lógica de Personal: El código ahora detecta si el Piso 3 (Personal 3) sobrepasa las 213 posiciones. Si lo hace, ese "sobrante" se le suma visualmente al Piso 4, y viceversa. Esto permite que el total de agentes de Personal se mantenga correcto pero se distribuya según la capacidad física de los pisos 3 y 4.

KPI: La tarjeta de Ocupación Promedio fue eliminada del grid para que las otras 3 luzcan más amplias.

