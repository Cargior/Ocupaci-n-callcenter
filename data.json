function prog(p,l){document.getElementById('pf').style.width=p+'%';document.getElementById('pll').textContent=l;}

function handle(f){
    if(!f)return;
    document.getElementById('dtt').textContent=f.name;
    document.getElementById('pw').style.display='block';
    document.getElementById('res').style.display='none';
    document.getElementById('err').style.display='none';
    document.getElementById('dl').disabled=true;
    setTimeout(()=>process(f),50);
}

function process(file){
  const reader=new FileReader();
  reader.onload=e=>{
    try{
      prog(10,'Leyendo Excel...');
      const wb=XLSX.read(e.target.result,{type:'array',cellDates:true});
      // LEER SOLAPA DE LA NUEVA MACRO
      const wsMax = wb.Sheets['Max Ocupación x Franja'];
      const wsAsig = wb.Sheets['ASIGNACION'];
      if(!wsMax) throw new Error('No se encontró la hoja "Max Ocupación x Franja". ¿Ejecutaste la nueva macro?');
      
      prog(30,'Cargando asignaciones...');
      const asigRows = XLSX.utils.sheet_to_json(wsAsig || {});
      const asigMap = {}; let totalPos = 0;
      asigRows.forEach(r=>{
          if(r.Cliente && r.Posiciones){
              asigMap[r.Cliente] = {pos: +r.Posiciones, piso: String(r.PISO||'?')};
              totalPos += +r.Posiciones;
          }
      });

      prog(60,'Procesando histórico...');
      const rows = XLSX.utils.sheet_to_json(wsMax);
      const dpc = {}; // daily_per_client
      const dailyMap = {};

      rows.forEach(row => {
        // La macro entrega la fecha en la columna "Fecha"
        let fRaw = row['Fecha'];
        let fecha = (fRaw instanceof Date) ? fRaw.toISOString().slice(0,10) : String(fRaw);
        let cli = row['Cliente'];
        let fte = parseFloat(row['Max FTE (Pres)']) || 0;

        if(!dpc[fecha]) dpc[fecha] = {};
        dpc[fecha][cli] = (dpc[fecha][cli] || 0) + fte;

        if(!dailyMap[fecha]) dailyMap[fecha] = { pico: 0, dow: new Date(fecha+'T12:00:00').getDay() };
        dailyMap[fecha].pico += fte;
      });

      const daily = Object.entries(dailyMap).map(([f, v]) => ({
        Fecha: f,
        pico_total: parseFloat(v.pico.toFixed(2)),
        occ_pct: parseFloat((v.pico / totalPos * 100).toFixed(1)),
        dow: v.dow
      })).sort((a,b)=>a.Fecha.localeCompare(b.Fecha));

      const now = new Date();
      const updated = now.toLocaleDateString('es-AR');
      
      jd = {
          meta: { 
              total_pos: totalPos, 
              updated, 
              periodo: daily.length ? `${daily[0].Fecha} - ${daily[daily.length-1].Fecha}` : '-',
              asigMap 
          },
          daily,
          daily_per_client: dpc,
          byClient: [] // Se podría calcular aquí o dejar que el index.html lo haga
      };

      prog(100,'Procesamiento completado');
      document.getElementById('res').style.display='block';
      document.getElementById('dl').disabled=false;
      document.getElementById('r-per').textContent = jd.meta.periodo;
      document.getElementById('r-pos').textContent = totalPos;
    } catch(err) {
      document.getElementById('pw').style.display='none';
      const el=document.getElementById('err'); el.style.display='block'; el.textContent='Error: '+err.message;
    }
  };
  reader.readAsArrayBuffer(file);
}

function download(){
    const blob=new Blob([JSON.stringify(jd,null,2)],{type:'application/json'});
    const a=document.createElement('a');
    a.href=URL.createObjectURL(blob);
    a.download='data.json';
    a.click();
}
</script>
